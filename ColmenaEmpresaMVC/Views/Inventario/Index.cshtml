@model IEnumerable<ColmenaEmpresa.Models.ItemInventario>
@{
    ViewData["Title"] = "Inventario";
    ViewData["Subtitle"] = ViewBag.ItemsTotales + " ítems en stock";
}

@section Actions {
    <a class="btn btn-sm" asp-action="Exportar" target="_blank">⬇ Exportar</a>
    @if (User.IsInRole("ADMIN"))
    {
        <a class="btn btn-primary btn-sm" asp-action="Crear">+ Nuevo ítem</a>
    }
}

<div class="g3 mb-6">
    <div class="stat-card"><div class="stat-lbl">Bajo stock</div><div class="stat-val c-amber">@ViewBag.BajoMinimo</div></div>
    <div class="stat-card"><div class="stat-lbl">Agotados / críticos</div><div class="stat-val c-red">@ViewBag.Agotados</div></div>
    <div class="stat-card"><div class="stat-lbl">Ítems totales</div><div class="stat-val c-gold">@ViewBag.ItemsTotales</div></div>
</div>

<div class="tbl-wrap">
    <div style="background:var(--bg-2);padding:14px 20px;border-bottom:1px solid var(--bdr);display:flex;align-items:center;justify-content:space-between">
        <span style="font-family:var(--serif);font-size:16px;color:var(--txt-1)">Stock actual</span>
    </div>
    @if (!Model.Any())
    {
        <div style="padding:32px;text-align:center;color:var(--txt-4);font-size:13px">
            Sin ítems en el inventario. Agregá el primero con <strong>+ Nuevo ítem</strong>.
        </div>
    }
    @foreach (var item in Model)
    {
        var barColor = item.EstadoStock == "rojo" ? "var(--red)" : item.EstadoStock == "amarillo" ? "var(--amber)" : "var(--green)";
        var pillCls  = item.EstadoStock == "rojo" ? "p-red" : item.EstadoStock == "amarillo" ? "p-amber" : "p-green";
        var pillTxt  = item.EstadoStock == "rojo" ? "Crítico" : item.EstadoStock == "amarillo" ? "Bajo" : "OK";
        <div class="inv-row">
            <div class="inv-name">@item.Nombre</div>
            <div class="inv-bar"><div class="inv-fill" style="width:@(item.PorcentajeStock)%;background:@barColor"></div></div>
            <div class="inv-qty">@item.CantidadActual @item.Unidad</div>
            <span class="pill @pillCls">@pillTxt</span>
            @if (User.IsInRole("ADMIN"))
            {
                <a class="btn btn-xs btn-icon" asp-action="Editar" asp-route-id="@item.Id" title="Editar">✏</a>
                <form asp-action="Eliminar" asp-route-id="@item.Id" method="post" style="display:inline" onsubmit="return confirm('¿Eliminar @item.Nombre del inventario?')">
                    @Html.AntiForgeryToken()
                    <button type="submit" class="btn btn-xs btn-icon" style="color:var(--red)" title="Eliminar">🗑</button>
                </form>
            }
        </div>
    }
</div>
