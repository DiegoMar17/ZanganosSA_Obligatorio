@model IEnumerable<ColmenaEmpresa.Models.Cosecha>
@{
    ViewData["Title"] = "Producción";
    ViewData["Subtitle"] = "Cosecha temporada 2025–26";
}

@section Actions {
    <a class="btn btn-sm" asp-action="Exportar" target="_blank">⬇ Exportar</a>
    <a class="btn btn-primary btn-sm" asp-action="Crear">+ Registrar cosecha</a>
}

<div class="g4 mb-6">
    <div class="stat-card"><div class="stat-lbl">Cosecha total</div><div class="stat-val c-gold">@ViewBag.TotalKg kg</div><div class="stat-meta">Temporada 2025–26</div></div>
    <div class="stat-card"><div class="stat-lbl">Mejor apiario</div><div class="stat-val" style="font-family:var(--serif);font-size:18px;color:var(--gold)">@ViewBag.MejorApiario</div><div class="stat-meta">@ViewBag.MejorKg kg</div></div>
    <div class="stat-card"><div class="stat-lbl">Promedio por cosecha</div><div class="stat-val c-gold">@ViewBag.Promedio kg</div></div>
    <div class="stat-card"><div class="stat-lbl">N° de cosechas</div><div class="stat-val c-green">@ViewBag.Cantidad</div></div>
</div>

<div class="card">
    <div class="card-hd"><div class="card-title">Producción por apiario</div></div>
    @if (!Model.Any())
    {
        <div style="padding:24px;color:var(--txt-4);text-align:center">Sin cosechas registradas aún.</div>
    }
    else
    {
        var maxPeso = Model.Max(m => m.PesoBruto);
        @foreach (var item in Model)
        {
            <div class="prod-row">
                <div class="prod-name">@item.ApiarioNombre</div>
                <div class="prod-bar"><div class="prod-fill" style="width:@(maxPeso > 0 ? item.PesoBruto * 100 / maxPeso : 0)%;background:var(--gold)"></div></div>
                <div class="prod-val c-gold">@item.PesoNeto kg</div>
                <a class="btn btn-xs btn-icon" asp-action="Editar" asp-route-id="@item.Id" title="Editar">✏</a>
                <form asp-action="Eliminar" asp-route-id="@item.Id" method="post" style="display:inline" onsubmit="return confirm('¿Eliminar esta cosecha?')">
                    @Html.AntiForgeryToken()
                    <button type="submit" class="btn btn-xs btn-icon" style="color:var(--red)" title="Eliminar">🗑</button>
                </form>
            </div>
        }
    }
</div>
