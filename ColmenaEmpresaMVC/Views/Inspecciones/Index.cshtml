@model IEnumerable<ColmenaEmpresa.Models.Inspeccion>
@{
    ViewData["Title"] = "Inspecciones";
    ViewData["Subtitle"] = ViewBag.Pendientes + " pendientes esta semana";
}

@section Actions {
    <button class="btn btn-primary btn-sm">+ Nueva inspección</button>
}

<div class="g3 mb-6">
    <div class="stat-card"><div class="stat-lbl">Pendientes</div><div class="stat-val c-red">@ViewBag.Pendientes</div><div class="stat-meta">Vencidas esta semana</div></div>
    <div class="stat-card"><div class="stat-lbl">Este mes</div><div class="stat-val c-gold">@ViewBag.EsteMes</div></div>
    <div class="stat-card"><div class="stat-lbl">Completadas</div><div class="stat-val c-green">@ViewBag.Completadas</div><div class="stat-meta">Temporada actual</div></div>
</div>

<div class="tbl-wrap">
    <table>
        <thead>
            <tr>
                <th>Apiario</th>
                <th>Colmenas</th>
                <th>Fecha</th>
                <th>Clima</th>
                <th>Temp.</th>
                <th>Estado</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td class="td-1">@item.ApiarioNombre</td>
                    <td>@item.ColmenasInspeccionadas / @item.TotalColmenas</td>
                    <td>@item.Fecha.ToString("dd MMM yyyy")</td>
                    <td>@item.Clima</td>
                    <td>@item.Temperatura°C</td>
                    <td><span class="pill p-@(item.Estado == "completa" ? "green" : "amber")">@item.Estado</span></td>
                </tr>
            }
        </tbody>
    </table>
</div>
