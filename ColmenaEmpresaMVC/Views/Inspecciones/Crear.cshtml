@model ColmenaEmpresa.Models.Inspeccion
@{
    ViewData["Title"] = "Nueva Inspección";
    ViewData["Subtitle"] = "Registrar visita de campo";
}

<div class="form-wrap">
    <div class="form-title">🔍 Nueva inspección de campo</div>
    <div class="form-desc">Registrá la visita con el estado de cada colmena y tus observaciones.</div>
    
    <div class="stepper">
        <div class="step act"><div class="step-c">1</div><div class="step-lbl">Datos generales</div></div>
        <div class="step"><div class="step-c">2</div><div class="step-lbl">Colmenas</div></div>
        <div class="step"><div class="step-c">3</div><div class="step-lbl">Cierre</div></div>
    </div>

    <form asp-action="Crear" method="post">
        <div class="fg">
            <div class="fgrp">
                <label class="flbl">Apiario <span class="req">*</span></label>
                <select asp-for="ApiarioId" class="fc" required>
                    <option value="1">La Rinconada</option>
                    <option value="2">Monte Olivo</option>
                    <option value="3">El Eucaliptal</option>
                </select>
            </div>
            <div class="fgrp">
                <label class="flbl">Fecha <span class="req">*</span></label>
                <input asp-for="Fecha" class="fc" type="date" required>
            </div>
            <div class="fgrp">
                <label class="flbl">Clima</label>
                <select asp-for="Clima" class="fc">
                    <option>☀ Soleado</option>
                    <option>⛅ Parcialmente nublado</option>
                    <option>☁ Nublado</option>
                    <option>🌧 Lluvia</option>
                </select>
            </div>
            <div class="fgrp">
                <label class="flbl">Temperatura (°C)</label>
                <input asp-for="Temperatura" class="fc" type="number">
            </div>
        </div>

        <div class="fs" style="margin-top:22px">Colmenas inspeccionadas</div>
        <div class="checklist mb-4">
            <div class="cl-row on" onclick="this.classList.toggle('on')"><div class="cl-box"></div>Colmena C-01 — reina vista, buena postura</div>
            <div class="cl-row on" onclick="this.classList.toggle('on')"><div class="cl-box"></div>Colmena C-02 — sin novedad</div>
            <div class="cl-row" onclick="this.classList.toggle('on')"><div class="cl-box"></div>Colmena C-03 — pendiente</div>
        </div>

        <div class="fgrp fg-full">
            <label class="flbl">Notas de campo</label>
            <textarea asp-for="NotasCampo" class="fc" placeholder="Detalles de la visita…"></textarea>
        </div>

        <div class="form-footer">
            <a asp-action="Index" class="btn">Cancelar</a>
            <button type="submit" class="btn btn-primary">Guardar inspección</button>
        </div>
    </form>
</div>
