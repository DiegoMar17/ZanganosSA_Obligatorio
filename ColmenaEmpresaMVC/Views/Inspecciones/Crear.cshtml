@model ColmenaEmpresa.Models.Inspeccion
@using ColmenaEmpresa.Models
@{
    ViewData["Title"] = "Nueva Inspección";
    ViewData["Subtitle"] = "Registrar visita de campo";
    var colmenas = (List<Colmena>)ViewBag.Colmenas;
    var grupos = colmenas.GroupBy(c => c.ApiarioNombre).OrderBy(g => g.Key);
}

<div class="form-wrap">
    <div class="form-title">🔍 Nueva inspección de campo</div>
    <div class="form-desc">Registrá la visita con el estado y tus observaciones.</div>

    <form asp-action="Crear" method="post">
        @Html.AntiForgeryToken()
        <div asp-validation-summary="ModelOnly" class="fhint mb-4" style="color:var(--red);background:var(--red-bg);border-radius:var(--r-sm);padding:10px 14px"></div>

        <input type="hidden" asp-for="TipoInspeccion" id="tipo-hidden" value="apiario" />

        <div class="fgrp fg-full" style="margin-bottom:24px">
            <label class="flbl">Tipo de inspección <span class="req">*</span></label>
            <div style="display:flex;gap:10px;margin-top:6px">
                <button type="button" id="btn-tipo-apiario" onclick="setTipo('apiario')"
                    class="btn btn-primary btn-sm" style="flex:1">
                    📍 Por apiario
                </button>
                <button type="button" id="btn-tipo-colmena" onclick="setTipo('colmena')"
                    class="btn btn-sm" style="flex:1">
                    🏠 Colmena específica
                </button>
            </div>
        </div>

        <div class="fg">
            <div id="sec-apiario" class="fgrp">
                <label class="flbl">Apiario <span class="req">*</span></label>
                <select asp-for="ApiarioId" class="fc" asp-items="ViewBag.Apiarios">
                    <option value="">Seleccionar…</option>
                </select>
                <span asp-validation-for="ApiarioId" class="fhint" style="color:var(--red)"></span>
            </div>

            <div id="sec-colmena" class="fgrp" style="display:none">
                <label class="flbl">Colmena <span class="req">*</span></label>
                <select asp-for="ColmenaId" id="colmena-select" class="fc">
                    <option value="">Seleccionar colmena…</option>
                    @foreach (var grupo in grupos)
                    {
                        <optgroup label="📍 @grupo.Key">
                            @foreach (var c in grupo)
                            {
                                <option value="@c.Id">@c.Codigo</option>
                            }
                        </optgroup>
                    }
                </select>
            </div>

            <div class="fgrp">
                <label class="flbl">Fecha <span class="req">*</span></label>
                <input asp-for="Fecha" class="fc" type="date">
                <span asp-validation-for="Fecha" class="fhint" style="color:var(--red)"></span>
            </div>
            <div class="fgrp">
                <label class="flbl">Clima</label>
                <select asp-for="Clima" class="fc">
                    <option>☀ Soleado</option>
                    <option>⛅ Parcialmente nublado</option>
                    <option>☁ Nublado</option>
                    <option>🌧 Lluvia</option>
                </select>
            </div>
            <div class="fgrp">
                <label class="flbl">Temperatura (°C)</label>
                <input asp-for="Temperatura" class="fc" type="number" min="-10" max="50">
                <span asp-validation-for="Temperatura" class="fhint" style="color:var(--red)"></span>
            </div>
        </div>

        <div class="fgrp fg-full" style="margin-top:8px">
            <label class="flbl">Notas de campo</label>
            <textarea asp-for="NotasCampo" class="fc" rows="4" placeholder="Detalles de la visita…"></textarea>
        </div>

        <div class="form-footer">
            <a asp-action="Index" class="btn">Cancelar</a>
            <button type="submit" class="btn btn-primary">Guardar inspección</button>
        </div>
    </form>
</div>

@section Scripts {
    @await Html.PartialAsync("_ValidationScriptsPartial")
    <script>
        function setTipo(tipo) {
            document.getElementById('tipo-hidden').value = tipo;

            var secApiario = document.getElementById('sec-apiario');
            var secColmena = document.getElementById('sec-colmena');
            var btnApiario = document.getElementById('btn-tipo-apiario');
            var btnColmena = document.getElementById('btn-tipo-colmena');

            if (tipo === 'apiario') {
                secApiario.style.display = '';
                secColmena.style.display = 'none';
                btnApiario.className = 'btn btn-primary btn-sm';
                btnColmena.className = 'btn btn-sm';
            } else {
                secApiario.style.display = 'none';
                secColmena.style.display = '';
                btnApiario.className = 'btn btn-sm';
                btnColmena.className = 'btn btn-primary btn-sm';
            }
        }
    </script>
}
