@model ColmenaEmpresa.Models.Transhumancia
@{
    ViewData["Title"] = "Nuevo Traslado";
    ViewData["Subtitle"] = "Planificar transhumancia";
}

<div class="form-wrap">
    <div class="form-title">🚚 Planificar traslado</div>
    <div class="form-desc">Registrá el movimiento de colmenas entre apiarios.</div>

    <form asp-action="Crear" method="post">
        <div asp-validation-summary="ModelOnly" class="fhint mb-4" style="color:var(--red);background:var(--red-bg);border-radius:var(--r-sm);padding:10px 14px"></div>

        <div class="fg">
            <div class="fgrp">
                <label class="flbl">Nombre del traslado <span class="req">*</span></label>
                <input asp-for="Nombre" class="fc" placeholder="Ej: Primavera 2025">
                <span asp-validation-for="Nombre" class="fhint" style="color:var(--red)"></span>
            </div>
            <div class="fgrp">
                <label class="flbl">Colmenas <span class="req">*</span></label>
                <input asp-for="CantidadColmenas" class="fc" type="number" min="1">
                <span asp-validation-for="CantidadColmenas" class="fhint" style="color:var(--red)"></span>
            </div>
            <div class="fgrp">
                <label class="flbl">Origen <span class="req">*</span></label>
                <select asp-for="ApiarioOrigen" class="fc">
                    <option>Paso Carrasco</option>
                    <option>Monte Olivo</option>
                </select>
                <span asp-validation-for="ApiarioOrigen" class="fhint" style="color:var(--red)"></span>
            </div>
            <div class="fgrp">
                <label class="flbl">Destino <span class="req">*</span></label>
                <select asp-for="ApiarioDestino" class="fc">
                    <option>El Trébol (temporal)</option>
                    <option>La Rinconada</option>
                </select>
                <span asp-validation-for="ApiarioDestino" class="fhint" style="color:var(--red)"></span>
            </div>
            <div class="fgrp">
                <label class="flbl">Distancia (km)</label>
                <input asp-for="DistanciaKm" class="fc" type="number" step="0.1" style="color:var(--gold);font-weight:700">
                <span asp-validation-for="DistanciaKm" class="fhint" style="color:var(--red)"></span>
            </div>
            <div class="fgrp">
                <label class="flbl">Fecha de salida <span class="req">*</span></label>
                <input asp-for="FechaSalida" class="fc" type="date">
                <span asp-validation-for="FechaSalida" class="fhint" style="color:var(--red)"></span>
            </div>
            <div class="fgrp">
                <label class="flbl">Retorno estimado</label>
                <input asp-for="FechaRetorno" class="fc" type="date">
            </div>
            <div class="fgrp fg-full">
                <label class="flbl">Motivo</label>
                <textarea asp-for="Motivo" class="fc" placeholder="Motivo del traslado…"></textarea>
            </div>
        </div>

        <div class="form-footer">
            <a asp-action="Index" class="btn">Cancelar</a>
            <button type="submit" class="btn btn-primary">Registrar traslado</button>
        </div>
    </form>
</div>

@section Scripts {
    @await Html.PartialAsync("_ValidationScriptsPartial")
}
