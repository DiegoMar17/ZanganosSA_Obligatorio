@model IEnumerable<ColmenaEmpresa.Models.Transhumancia>
@{
    ViewData["Title"] = "Transhumancia";
    ViewData["Subtitle"] = "1 evento activo";
}

@section Actions {
    <a class="btn btn-primary btn-sm" asp-action="Crear">+ Nuevo traslado</a>
}

<div class="g2">
    @foreach (var item in Model.Where(m => m.Estado == "en_curso"))
    {
        <div class="card">
            <div class="card-hd"><div class="card-title">Evento activo — @item.Nombre</div><span class="pill p-blue">@item.Estado</span></div>
            <div class="g2 mb-4">
                <div><div style="font-size:11px;color:var(--txt-4);margin-bottom:3px;text-transform:uppercase;letter-spacing:.07em">Origen</div><div style="font-size:14px;font-weight:600;color:var(--txt-1)">@item.ApiarioOrigen</div></div>
                <div><div style="font-size:11px;color:var(--txt-4);margin-bottom:3px;text-transform:uppercase;letter-spacing:.07em">Destino</div><div style="font-size:14px;font-weight:600;color:var(--txt-1)">@item.ApiarioDestino</div></div>
                <div><div style="font-size:11px;color:var(--txt-4);margin-bottom:3px;text-transform:uppercase;letter-spacing:.07em">Colmenas</div><div class="stat-val c-gold" style="font-size:26px">@item.CantidadColmenas</div></div>
                <div><div style="font-size:11px;color:var(--txt-4);margin-bottom:3px;text-transform:uppercase;letter-spacing:.07em">Distancia</div><div class="stat-val c-gold" style="font-size:26px">@item.DistanciaKm km</div></div>
            </div>
            <div style="font-size:12px;color:var(--txt-4);margin-bottom:6px">Progreso — @item.PorcentajeAvance% del tiempo</div>
            <div class="prog mb-4"><div class="prog-fill" style="width:@(item.PorcentajeAvance)%"></div></div>
            <div style="font-size:12.5px;color:var(--txt-3)">Retorno estimado: @(item.FechaRetorno?.ToString("dd MMM yyyy") ?? "—")</div>
        </div>
    }

    <div class="card">
        <div class="card-hd"><div class="card-title">Historial</div></div>
        @foreach (var item in Model.Where(m => m.Estado == "completado"))
        {
            <div class="tl-item">
                <div class="tl-dot-col">
                    <div class="tl-dot" style="background:var(--green)"></div>
                    <div class="tl-line"></div>
                </div>
                <div class="tl-body">
                    <div class="tl-t">@item.Nombre — @item.CantidadColmenas colmenas</div>
                    <div class="tl-d">@item.ApiarioOrigen → @item.ApiarioDestino · @item.DistanciaKm km</div>
                </div>
            </div>
        }
    </div>
</div>
