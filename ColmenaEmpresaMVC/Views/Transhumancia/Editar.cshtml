@model ColmenaEmpresa.Models.Traslado
@{
    ViewData["Title"] = "Editar Traslado";
    ViewData["Subtitle"] = "Modificar traslado de colmenas";
}

<div class="form-wrap">
    <div class="form-title">🚚 Editar traslado</div>
    <div class="form-desc">Modificá los datos del movimiento de colmenas.</div>

    <form asp-action="Editar" asp-route-id="@Model.Id" method="post">
        <input type="hidden" asp-for="Id" />
        <div asp-validation-summary="ModelOnly" class="fhint mb-4" style="color:var(--red);background:var(--red-bg);border-radius:var(--r-sm);padding:10px 14px"></div>

        <div class="fg">
            <div class="fgrp">
                <label class="flbl">Nombre del traslado <span class="req">*</span></label>
                <input asp-for="Nombre" class="fc" placeholder="Ej: Primavera 2026">
                <span asp-validation-for="Nombre" class="fhint" style="color:var(--red)"></span>
            </div>
            <div class="fgrp">
                <label class="flbl">Colmenas <span class="req">*</span></label>
                <input asp-for="CantidadColmenas" class="fc" type="number" min="1">
                <span asp-validation-for="CantidadColmenas" class="fhint" style="color:var(--red)"></span>
            </div>
            <div class="fgrp">
                <label class="flbl">Origen <span class="req">*</span></label>
                <select asp-for="ApiarioOrigenId" asp-items="ViewBag.Apiarios" class="fc">
                    <option value="">Seleccionar…</option>
                </select>
                <span asp-validation-for="ApiarioOrigenId" class="fhint" style="color:var(--red)"></span>
            </div>
            <div class="fgrp">
                <label class="flbl">Destino <span class="req">*</span></label>
                <select asp-for="ApiarioDestinoId" asp-items="ViewBag.Apiarios" class="fc">
                    <option value="">Seleccionar…</option>
                </select>
                <span asp-validation-for="ApiarioDestinoId" class="fhint" style="color:var(--red)"></span>
            </div>
            <div class="fgrp">
                <label class="flbl">Distancia (km)</label>
                <input asp-for="DistanciaKm" class="fc" type="number" step="0.1">
                <span asp-validation-for="DistanciaKm" class="fhint" style="color:var(--red)"></span>
            </div>
            <div class="fgrp">
                <label class="flbl">Fecha de salida <span class="req">*</span></label>
                <input asp-for="FechaSalida" class="fc" type="date">
                <span asp-validation-for="FechaSalida" class="fhint" style="color:var(--red)"></span>
            </div>
            <div class="fgrp">
                <label class="flbl">Retorno estimado</label>
                <input asp-for="FechaRetorno" class="fc" type="date">
            </div>
            <div class="fgrp">
                <label class="flbl">Estado</label>
                <select asp-for="Estado" class="fc">
                    <option value="planificado">Planificado</option>
                    <option value="en_curso">En curso</option>
                    <option value="completado">Completado</option>
                </select>
            </div>
            <div class="fgrp fg-full">
                <label class="flbl">Motivo</label>
                <textarea asp-for="Motivo" class="fc" placeholder="Motivo del traslado…"></textarea>
            </div>
        </div>

        <div class="form-footer">
            <a asp-action="Index" class="btn">Cancelar</a>
            <button type="submit" class="btn btn-primary">Guardar cambios</button>
        </div>
    </form>
</div>

@section Scripts {
    @await Html.PartialAsync("_ValidationScriptsPartial")
}
