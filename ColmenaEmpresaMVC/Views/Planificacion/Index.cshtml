@{
    ViewData["Title"] = "Planificación";
    ViewData["Subtitle"] = "Tareas y visitas programadas";
}

@section Actions {
    <button class="btn btn-primary btn-sm" onclick="toast('Nueva tarea creada ✓')">+ Nueva tarea</button>
}

<div class="dual-panel">
    <div class="panel">
        <div class="panel-hd"><div class="panel-title">Tareas pendientes</div><span class="panel-cnt" id="task-cnt">4 pendientes</span></div>
        <div class="panel-body" id="task-panel">
            <div class="task-row"><div class="chk" onclick="toggleTask(this)"></div><div class="t-info"><div class="t-name">Aplicar tratamiento Varroa en La Rinconada</div><div class="t-tags"><span class="chip">Sanidad</span><span class="chip" style="color:var(--red);border-color:var(--red-bdr);background:var(--red-bg)">alta</span><span class="chip">25 abr</span></div></div></div>
            <div class="task-row"><div class="chk" onclick="toggleTask(this)"></div><div class="t-info"><div class="t-name">Reponer jarabe azucarado Monte Olivo</div><div class="t-tags"><span class="chip">Alimentación</span><span class="chip" style="color:var(--amber);border-color:var(--amber-bdr);background:var(--amber-bg)">media</span><span class="chip">27 abr</span></div></div></div>
            <div class="task-row"><div class="chk" onclick="toggleTask(this)"></div><div class="t-info"><div class="t-name">Revisar postura reinas antes de cosecha</div><div class="t-tags"><span class="chip">Inspección</span><span class="chip" style="color:var(--red);border-color:var(--red-bdr);background:var(--red-bg)">alta</span></div></div></div>
            <div class="task-row done"><div class="chk on" onclick="toggleTask(this)"></div><div class="t-info"><div class="t-name t-done">Pintar alzas dañadas lote B</div><div class="t-tags"><span class="chip">Mantenimiento</span></div></div></div>
        </div>
    </div>
    <div class="panel">
        <div class="panel-hd"><div class="panel-title">Visitas planificadas</div><span class="panel-cnt">3 pendientes</span></div>
        <div class="panel-body">
            <div class="visit-row"><div class="vdot-wrap"><div class="vdot vd-late"></div></div><div class="v-info"><div class="v-place">La Rinconada</div><div class="v-date">Plan: 14 abr · Vencida hace 8 días</div><div class="v-mats">🧰 Ácido oxálico, cuadernillo</div></div><span class="pill p-red" style="font-size:11px;flex-shrink:0">Vencida</span></div>
            <div class="visit-row"><div class="vdot-wrap"><div class="vdot vd-pend"></div></div><div class="v-info"><div class="v-place">El Eucaliptal</div><div class="v-date">Plan: 25 abr · En 3 días</div><div class="v-mats">🧰 Alzas de repuesto, extractor</div><button class="v-btn" onclick="toast('Visita marcada como realizada ✓')">Marcar realizada</button></div><span class="pill p-blue" style="font-size:11px;flex-shrink:0">Planificada</span></div>
            <div class="visit-row"><div class="vdot-wrap"><div class="vdot vd-ok"></div></div><div class="v-info"><div class="v-place">Monte Olivo</div><div class="v-date">Realizada: 18 abr 2024</div></div><span class="pill p-green" style="font-size:11px;flex-shrink:0">Completada</span></div>
        </div>
    </div>
</div>
