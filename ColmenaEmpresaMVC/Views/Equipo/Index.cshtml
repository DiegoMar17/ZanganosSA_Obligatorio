@model IEnumerable<ColmenaEmpresa.Controllers.EmpleadoEquipoViewModel>
@{
    ViewData["Title"]    = "Mi Equipo";
    ViewData["Subtitle"] = "Panel de empleados y actividad reciente";
    var total   = (int)ViewBag.TotalEmpleados;
    var activos = (int)ViewBag.EmpleadosActivos;
}

<div class="g3 mb-6">
    <div class="stat-card">
        <div class="stat-card-accent" style="background:var(--gold-dim)">👥</div>
        <div class="stat-lbl">Total empleados</div>
        <div class="stat-val c-gold">@total</div>
        <div class="stat-meta">Registrados en el equipo</div>
    </div>
    <div class="stat-card">
        <div class="stat-card-accent" style="background:var(--green-bg)">●</div>
        <div class="stat-lbl">Acceso activo</div>
        <div class="stat-val c-green">@activos</div>
        <div class="stat-meta">Con PIN habilitado</div>
    </div>
    <div class="stat-card">
        <div class="stat-card-accent" style="background:var(--red-bg)">✕</div>
        <div class="stat-lbl">Sin PIN / revocado</div>
        <div class="stat-val c-red">@(total - activos)</div>
        <div class="stat-meta">Requieren atención</div>
    </div>
</div>

<div class="card-grid" style="grid-template-columns:repeat(auto-fill,minmax(320px,1fr))">
    @foreach (var e in Model)
    {
        <div class="info-card" style="padding:22px">
            <div style="display:flex;align-items:center;gap:14px;margin-bottom:16px">
                <div style="width:44px;height:44px;border-radius:12px;background:var(--gold-dim);border:1px solid var(--bdr);display:flex;align-items:center;justify-content:center;font-size:20px">👷</div>
                <div>
                    <div style="font-weight:600;color:var(--txt-1)">@e.NombreCompleto</div>
                    <div style="font-size:12px;color:var(--txt-4)">@e.Email</div>
                </div>
                <div style="margin-left:auto">
                    @if (e.PinActivo)
                    {
                        <span class="pill p-g" style="font-size:11px">● Activo</span>
                    }
                    else if (e.TienePin)
                    {
                        <span class="pill p-r" style="font-size:11px">✕ Revocado</span>
                    }
                    else
                    {
                        <span class="pill" style="background:rgba(90,77,53,.3);color:var(--txt-3);font-size:11px">Sin PIN</span>
                    }
                </div>
            </div>
            <div style="display:flex;flex-direction:column;gap:8px">
                <div style="display:flex;justify-content:space-between;font-size:13px">
                    <span style="color:var(--txt-3)">Sector</span>
                    <span style="color:var(--txt-1)">@(string.IsNullOrEmpty(e.ApiarioNombre) ? "Sin asignar" : e.ApiarioNombre)</span>
                </div>
                <div style="display:flex;justify-content:space-between;font-size:13px">
                    <span style="color:var(--txt-3)">Registros esta semana</span>
                    <span style="color:var(--gold);font-weight:600">@e.RegistrosSemana</span>
                </div>
                <div style="display:flex;justify-content:space-between;font-size:13px">
                    <span style="color:var(--txt-3)">Último acceso</span>
                    <span style="color:var(--txt-2)">@(e.UltimoAcceso.HasValue ? e.UltimoAcceso.Value.ToString("dd/MM/yy HH:mm") : "Nunca")</span>
                </div>
            </div>
            <div style="margin-top:16px;padding-top:14px;border-top:1px solid var(--bdr);display:flex;justify-content:space-between;gap:10px">
                <a asp-controller="Equipo" asp-action="Detalle" asp-route-id="@e.UserId" style="font-size:12px;color:var(--gold);text-decoration:none;font-weight:600">👤 Ver perfil →</a>
                <a asp-controller="Pin" asp-action="Index" style="font-size:12px;color:var(--txt-3);text-decoration:none;">🔑 Gestionar PIN →</a>
            </div>
        </div>
    }

    @if (!Model.Any())
    {
        <div style="grid-column:1/-1;text-align:center;color:var(--txt-4);padding:48px 0">
            No hay empleados aún. <a asp-controller="Pin" asp-action="Index" style="color:var(--gold)">Creá uno en Gestión de PINs →</a>
        </div>
    }
</div>
