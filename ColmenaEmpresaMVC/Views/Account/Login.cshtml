@{
    Layout = null;
    var tabActivo = ViewBag.TabActivo as string ?? "admin";
}
<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Ingresar — ZanganosSA</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@300;400;500;600;700&family=DM+Serif+Display&display=swap" rel="stylesheet">
    <script>document.documentElement.setAttribute('data-theme', localStorage.getItem('theme') || 'dark');</script>
    <style>
        *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
        :root {
            --gold: #F2BE30; --gold-glow: rgba(242,190,48,.2); --gold-dim: rgba(242,190,48,.10);
            --bg: #0C0A07; --bg-1: #131008; --bg-2: #1A1509;
            --txt-1: #F5EDD5; --txt-2: #C8AD78; --txt-3: #8A7650; --txt-4: #5A4D35;
            --bdr: rgba(242,190,48,.14); --bdr-2: rgba(242,190,48,.32);
            --red: #F26B6B; --red-bg: rgba(242,107,107,.12);
            --sans: 'DM Sans', system-ui, sans-serif;
            --serif: 'DM Serif Display', Georgia, serif;
        }
        [data-theme="light"] {
            --gold: #B8820A; --gold-glow: rgba(184,130,10,.18); --gold-dim: rgba(184,130,10,.08);
            --bg: #F7F2E8; --bg-1: #EDE6D5; --bg-2: #E3D9C4;
            --txt-1: #1A1408; --txt-2: #4A3C1E; --txt-3: #7A6840; --txt-4: #A8956A;
            --bdr: rgba(0,0,0,.10); --bdr-2: rgba(0,0,0,.22);
            --red: #CC3535; --red-bg: rgba(204,53,53,.10);
        }
        html, body { height: 100%; font-family: var(--sans); background: var(--bg); color: var(--txt-1); overflow: hidden; }
        canvas { position: fixed; inset: 0; z-index: 0; pointer-events: none; }
        .page { position: relative; z-index: 1; height: 100vh; display: flex; align-items: center; justify-content: center; padding: 24px; }
        .card {
            background: rgba(19,16,8,.88); border: 1px solid var(--bdr-2); border-radius: 24px;
            padding: 40px 44px; width: 100%; max-width: 440px;
            backdrop-filter: blur(20px); box-shadow: 0 32px 80px rgba(0,0,0,.6);
            animation: fadeUp .5s ease both;
        }
        .card-logo { display: flex; flex-direction: column; align-items: center; gap: 12px; margin-bottom: 28px; text-align: center; }
        .logo-mark { width: 56px; height: 56px; border-radius: 16px; background: var(--gold-dim); border: 1px solid var(--bdr-2); display: flex; align-items: center; justify-content: center; font-size: 28px; box-shadow: 0 0 40px var(--gold-glow); }
        .logo-name  { font-family: var(--serif); font-size: 22px; color: var(--gold); }
        .logo-sub   { font-size: 13px; color: var(--txt-4); }
        .tabs { display: flex; gap: 4px; margin-bottom: 24px; background: var(--bg-2); padding: 4px; border-radius: 12px; }
        .tab { flex: 1; padding: 9px 12px; border: none; border-radius: 9px; font-family: var(--sans); font-size: 13px; font-weight: 600; cursor: pointer; transition: all .2s; background: transparent; color: var(--txt-3); }
        .tab.active { background: var(--bg-1); color: var(--gold); border: 1px solid var(--bdr); }
        .tab:hover:not(.active) { color: var(--txt-2); }
        .tab-panel { display: none; }
        .tab-panel.active { display: block; }
        .error-box { background: var(--red-bg); border: 1px solid rgba(242,107,107,.3); border-radius: 10px; padding: 11px 14px; font-size: 13px; color: var(--red); margin-bottom: 20px; }
        .fgrp { display: flex; flex-direction: column; gap: 7px; margin-bottom: 16px; }
        .flbl { font-size: 12.5px; font-weight: 600; color: var(--txt-2); }
        .fc { background: var(--bg); border: 1.5px solid var(--bdr); border-radius: 10px; color: var(--txt-1); font-family: var(--sans); font-size: 14px; padding: 12px 14px; outline: none; width: 100%; transition: border-color .2s, box-shadow .2s; }
        .fc::placeholder { color: var(--txt-4); }
        .fc:focus { border-color: var(--gold); box-shadow: 0 0 0 3px var(--gold-glow); }
        .pin-input { letter-spacing: 0.3em; font-size: 18px; font-weight: 700; text-align: center; }
        .hint { font-size: 11.5px; color: var(--txt-4); margin-top: 16px; text-align: center; }
        .hint strong { color: var(--gold); font-family: monospace; }
        .btn { width: 100%; padding: 13px; background: var(--gold); color: #0C0A07; font-family: var(--sans); font-size: 15px; font-weight: 700; border: none; border-radius: 10px; cursor: pointer; transition: all .2s; box-shadow: 0 4px 20px var(--gold-glow); margin-top: 8px; }
        .btn:hover { filter: brightness(1.08); transform: translateY(-2px); }
        .back { display: block; text-align: center; margin-top: 18px; font-size: 13px; color: var(--txt-4); text-decoration: none; }
        .back:hover { color: var(--txt-2); }
        .theme-btn-login { position: fixed; top: 18px; right: 24px; width: 36px; height: 36px; border-radius: 9px; background: var(--bg-2); border: 1px solid var(--bdr); color: var(--txt-3); font-size: 16px; display: flex; align-items: center; justify-content: center; cursor: pointer; transition: all .2s; z-index: 10; }
        .theme-btn-login:hover { border-color: var(--bdr-2); color: var(--gold); }
        @@keyframes fadeUp { from { opacity:0; transform:translateY(20px); } to { opacity:1; transform:translateY(0); } }
    </style>
</head>
<body>
    <canvas id="cv"></canvas>
    <button class="theme-btn-login" id="theme-login" title="Cambiar tema">🌙</button>
    <div class="page">
        <div class="card">
            <div class="card-logo">
                <div class="logo-mark">🐝</div>
                <div class="logo-name">ZanganosSA</div>
                <div class="logo-sub">Sistema de gestión apícola</div>
            </div>

            <div class="tabs">
                <button class="tab @(tabActivo == "admin" ? "active" : "")" onclick="switchTab('admin')">👑 Administrador</button>
                <button class="tab @(tabActivo == "pin" ? "active" : "")" onclick="switchTab('pin')">🔑 Empleado PIN</button>
            </div>

            <!-- Tab Admin: email + contraseña -->
            <div class="tab-panel @(tabActivo == "admin" ? "active" : "")" id="tab-admin">
                @if (ViewBag.Error != null)
                {
                    <div class="error-box">⚠ @ViewBag.Error</div>
                }
                <form method="post" asp-action="Login" asp-route-returnUrl="@ViewBag.ReturnUrl">
                    @Html.AntiForgeryToken()
                    <div class="fgrp">
                        <label class="flbl">Email</label>
                        <input type="email" name="email" class="fc" placeholder="admin@colmena.com" required autofocus>
                    </div>
                    <div class="fgrp">
                        <label class="flbl">Contraseña</label>
                        <input type="password" name="password" class="fc" placeholder="••••••••" required>
                    </div>
                    <button type="submit" class="btn">Ingresar como Admin →</button>
                </form>
                <div class="hint">Credenciales por defecto: <strong>admin@colmena.com</strong> / <strong>colmena123</strong></div>
            </div>

            <!-- Tab Empleado: email + PIN -->
            <div class="tab-panel @(tabActivo == "pin" ? "active" : "")" id="tab-pin">
                @if (ViewBag.ErrorPin != null)
                {
                    <div class="error-box">⚠ @ViewBag.ErrorPin</div>
                }
                <form method="post" asp-action="LoginPin" asp-route-returnUrl="@ViewBag.ReturnUrl">
                    @Html.AntiForgeryToken()
                    <div class="fgrp">
                        <label class="flbl">Tu Email</label>
                        <input type="email" name="email" class="fc" placeholder="empleado@colmena.com" required>
                    </div>
                    <div class="fgrp">
                        <label class="flbl">PIN (6 dígitos)</label>
                        <input type="password" name="pin" class="fc pin-input" placeholder="• • • • • •" maxlength="6" pattern="[0-9]{6}" inputmode="numeric" required>
                    </div>
                    <button type="submit" class="btn">Ingresar con PIN →</button>
                </form>
                <div class="hint">Tu PIN es asignado por el administrador.</div>
            </div>

            <a href="@Url.Action("Landing", "Home")" class="back">← Volver al inicio</a>
        </div>
    </div>
    <script>
        function switchTab(tab) {
            document.querySelectorAll('.tab').forEach(t => t.classList.remove('active'));
            document.querySelectorAll('.tab-panel').forEach(p => p.classList.remove('active'));
            document.getElementById('tab-' + tab).classList.add('active');
            event.target.classList.add('active');
        }
        (function(){
            const btn = document.getElementById('theme-login');
            const apply = (t) => { document.documentElement.setAttribute('data-theme', t); localStorage.setItem('theme', t); btn.textContent = t === 'dark' ? '🌙' : '☀️'; };
            apply(localStorage.getItem('theme') || 'dark');
            btn.addEventListener('click', () => apply(document.documentElement.getAttribute('data-theme') === 'dark' ? 'light' : 'dark'));
        })();
        (function(){
            const cv=document.getElementById('cv'), cx=cv.getContext('2d');
            const R=26,GAP=3; let mx=-9999,my=-9999,h=[];
            function build(){h=[];const W=(2*R+GAP)*.75,H=(Math.sqrt(3)*R+GAP);for(let c=-1;c<Math.ceil(cv.width/W)+2;c++)for(let r=-1;r<Math.ceil(cv.height/H)+2;r++)h.push({x:c*W,y:r*H+(c%2?H/2:0),g:0});}
            function hex(x,y,r){cx.beginPath();for(let i=0;i<6;i++){const a=Math.PI/180*(60*i-30);i?cx.lineTo(x+r*Math.cos(a),y+r*Math.sin(a)):cx.moveTo(x+r*Math.cos(a),y+r*Math.sin(a));}cx.closePath();}
            function resize(){cv.width=window.innerWidth;cv.height=window.innerHeight;build();}
            function draw(){cx.clearRect(0,0,cv.width,cv.height);h.forEach(e=>{const d=Math.hypot(mx-e.x,my-e.y);e.g+=((d<120?(1-d/120)*.7:0)-e.g)*.12;const a=.032+e.g*.6;hex(e.x,e.y,R-1.5);cx.fillStyle=`rgba(242,190,48,${(a*.4).toFixed(3)})`;cx.fill();cx.strokeStyle=`rgba(242,190,48,${a.toFixed(3)})`;cx.lineWidth=e.g>.06?1.3:.6;cx.stroke();});requestAnimationFrame(draw);}
            window.addEventListener('resize',resize);window.addEventListener('mousemove',e=>{mx=e.clientX;my=e.clientY;});
            resize();draw();
        })();
    </script>
</body>
</html>
