@model ColmenaEmpresa.Models.PagedResult<ColmenaEmpresa.Models.ControlSanitario>
@{
    ViewData["Title"] = "Sanidad";
    ViewData["Subtitle"] = ViewBag.ControlesActivos + " controles activos";
}

@section Actions {
    @if (User.IsInRole("ADMIN"))
    {
        <a class="btn btn-sm" asp-action="Exportar" target="_blank">⬇ Exportar</a>
    }
    <a class="btn btn-primary btn-sm" asp-action="Crear">+ Control sanitario</a>
}

<div class="g3 mb-6">
    <div class="stat-card"><div class="stat-lbl">Controles activos</div><div class="stat-val c-amber">@ViewBag.ControlesActivos</div></div>
    <div class="stat-card"><div class="stat-lbl">Varroa detectado</div><div class="stat-val c-red">@ViewBag.VarroaDetectado</div></div>
    <div class="stat-card"><div class="stat-lbl">Tratados OK</div><div class="stat-val c-green">@ViewBag.TratadosOk</div></div>
</div>

<div class="flex-between mb-4">
    <form method="get" asp-action="Index" style="display:flex;gap:8px;align-items:center">
        <input type="text" name="q" value="@Model.Q" class="fc" placeholder="Buscar por apiario, control…" style="max-width:280px">
        <button type="submit" class="btn btn-sm">Buscar</button>
        @if (!string.IsNullOrWhiteSpace(Model.Q))
        {
            <a class="btn btn-sm" asp-action="Index">✕ Limpiar</a>
        }
    </form>
</div>

<div class="tbl-wrap">
    <table>
        <thead>
            <tr>
                <th>Colmena</th>
                <th>Control</th>
                <th>Resultado</th>
                <th>Tratamiento</th>
                <th>Fecha</th>
                <th>Estado</th>
                <th></th>
            </tr>
        </thead>
        <tbody>
            @if (!Model.Items.Any())
            {
                <tr><td colspan="7" style="text-align:center;color:var(--txt-4);padding:28px">Sin resultados.</td></tr>
            }
            @foreach (var item in Model.Items)
            {
                <tr>
                    <td class="td-1">@item.ColmenasAfectadas</td>
                    <td>@item.TipoControl</td>
                    <td>
                        @{
                            var resColor = item.Resultado == "positivo" ? "var(--red)" : item.Resultado == "dudoso" ? "var(--amber)" : "var(--green)";
                            var resTxt   = string.IsNullOrEmpty(item.Resultado) ? "—" : char.ToUpper(item.Resultado[0]) + item.Resultado[1..];
                        }
                        <span style="color:@resColor;font-weight:600">@resTxt</span>
                    </td>
                    <td>@item.Tratamiento</td>
                    <td>@item.Fecha.ToString("dd MMM yyyy")</td>
                    <td><span class="pill p-@(item.Estado == "limpio" ? "green" : "amber")">@(item.Estado == "limpio" ? "Limpio" : "En tratamiento")</span></td>
                    <td style="display:flex;gap:6px">
                        @if (User.IsInRole("ADMIN"))
                        {
                            <a class="btn btn-xs btn-icon" asp-action="Editar" asp-route-id="@item.Id" title="Editar">✏</a>
                            <form asp-action="Eliminar" asp-route-id="@item.Id" method="post" style="display:inline" onsubmit="return confirm('¿Eliminar este control?')">
                                @Html.AntiForgeryToken()
                                <button type="submit" class="btn btn-xs btn-icon" style="color:var(--red)" title="Eliminar">🗑</button>
                            </form>
                        }
                    </td>
                </tr>
            }
        </tbody>
    </table>
    @await Html.PartialAsync("_Pagination", Model)
</div>
