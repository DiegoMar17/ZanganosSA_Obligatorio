@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>ColmenaEmpresa — Gestión Apícola</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@300;400;500;600;700&family=DM+Serif+Display:ital@0;1&display=swap" rel="stylesheet">
    <style>
        *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

        :root {
            --gold:      #F2BE30;
            --gold-2:    #FACCAA;
            --gold-glow: rgba(242,190,48,.25);
            --gold-dim:  rgba(242,190,48,.10);
            --bg:        #0C0A07;
            --bg-1:      #131008;
            --bg-2:      #1A1509;
            --bg-3:      #221C0C;
            --txt-1:     #F5EDD5;
            --txt-2:     #C8AD78;
            --txt-3:     #8A7650;
            --txt-4:     #5A4D35;
            --bdr:       rgba(242,190,48,.14);
            --bdr-2:     rgba(242,190,48,.32);
            --green:     #52C98B;
            --red:       #F26B6B;
            --amber:     #F0A835;
            --blue:      #6BAEE8;
            --sans:      'DM Sans', system-ui, sans-serif;
            --serif:     'DM Serif Display', Georgia, serif;
        }

        html, body {
            height: 100%;
            font-family: var(--sans);
            background: var(--bg);
            color: var(--txt-1);
            overflow-x: hidden;
        }

        canvas#hex-bg {
            position: fixed;
            inset: 0;
            z-index: 0;
            pointer-events: none;
        }

        /* ── NAV ── */
        nav {
            position: fixed;
            top: 0; left: 0; right: 0;
            z-index: 50;
            display: flex;
            align-items: center;
            justify-content: space-between;
            padding: 18px 48px;
            background: rgba(12,10,7,.6);
            backdrop-filter: blur(14px);
            border-bottom: 1px solid var(--bdr);
            animation: fadeDown .6s ease both;
        }
        .nav-logo { display: flex; align-items: center; gap: 10px; }
        .nav-logo-mark {
            width: 36px; height: 36px;
            border-radius: 10px;
            background: var(--gold-dim);
            border: 1px solid var(--bdr-2);
            display: flex; align-items: center; justify-content: center;
            font-size: 18px;
        }
        .nav-logo-name {
            font-family: var(--serif);
            font-size: 18px;
            color: var(--gold);
        }
        .nav-pill {
            font-size: 11px; font-weight: 700;
            letter-spacing: .08em; text-transform: uppercase;
            color: var(--txt-4);
            background: var(--bg-2);
            border: 1px solid var(--bdr);
            border-radius: 99px;
            padding: 5px 14px;
        }

        /* ── HERO ── */
        .hero {
            position: relative;
            z-index: 1;
            min-height: 100vh;
            display: grid;
            grid-template-columns: 1fr 1fr;
            align-items: center;
            padding: 120px 48px 80px;
            gap: 60px;
            max-width: 1280px;
            margin: 0 auto;
        }

        /* LEFT */
        .hero-left { display: flex; flex-direction: column; gap: 0; }

        .hero-badge {
            display: inline-flex;
            align-items: center;
            gap: 8px;
            font-size: 12px; font-weight: 700;
            letter-spacing: .09em; text-transform: uppercase;
            color: var(--gold);
            background: var(--gold-dim);
            border: 1px solid var(--bdr-2);
            border-radius: 99px;
            padding: 7px 18px;
            width: fit-content;
            margin-bottom: 32px;
            animation: fadeUp .7s .1s ease both;
        }
        .hero-badge-dot {
            width: 6px; height: 6px;
            border-radius: 50%;
            background: var(--green);
            box-shadow: 0 0 8px var(--green);
            animation: pulse 2s infinite;
        }

        h1 {
            font-family: var(--serif);
            font-size: clamp(42px, 5.5vw, 72px);
            line-height: 1.05;
            letter-spacing: -.01em;
            color: var(--txt-1);
            margin-bottom: 24px;
            animation: fadeUp .7s .2s ease both;
        }
        h1 .accent { color: var(--gold); font-style: italic; }
        h1 .line2  { display: block; color: var(--txt-2); }

        .hero-desc {
            font-size: 17px;
            color: var(--txt-3);
            line-height: 1.65;
            max-width: 460px;
            margin-bottom: 40px;
            animation: fadeUp .7s .3s ease both;
        }

        .hero-cta {
            display: flex;
            align-items: center;
            gap: 14px;
            margin-bottom: 52px;
            animation: fadeUp .7s .4s ease both;
        }
        .btn-primary {
            display: inline-flex;
            align-items: center;
            gap: 10px;
            background: var(--gold);
            color: #0C0A07;
            font-family: var(--sans);
            font-size: 15px;
            font-weight: 700;
            padding: 15px 32px;
            border-radius: 12px;
            border: none;
            cursor: pointer;
            text-decoration: none;
            transition: all .22s cubic-bezier(.4,0,.2,1);
            box-shadow: 0 4px 28px var(--gold-glow), 0 0 0 0 var(--gold-glow);
        }
        .btn-primary:hover {
            filter: brightness(1.1);
            transform: translateY(-3px);
            box-shadow: 0 12px 40px var(--gold-glow);
        }
        .btn-primary .arrow {
            font-size: 18px;
            transition: transform .2s;
        }
        .btn-primary:hover .arrow { transform: translateX(4px); }

        .btn-ghost {
            font-size: 14px; font-weight: 500;
            color: var(--txt-3);
            text-decoration: none;
            display: flex; align-items: center; gap: 6px;
            transition: color .2s;
        }
        .btn-ghost:hover { color: var(--txt-1); }

        /* Stats row */
        .hero-stats {
            display: flex;
            gap: 32px;
            animation: fadeUp .7s .5s ease both;
        }
        .stat { display: flex; flex-direction: column; gap: 2px; }
        .stat-n {
            font-family: var(--serif);
            font-size: 28px;
            color: var(--gold);
            line-height: 1;
        }
        .stat-l { font-size: 12px; color: var(--txt-4); }
        .stat-div {
            width: 1px;
            background: var(--bdr);
            align-self: stretch;
        }

        /* RIGHT */
        .hero-right {
            display: flex;
            flex-direction: column;
            gap: 16px;
            animation: fadeLeft .8s .3s ease both;
        }

        .glass-card {
            background: rgba(19,16,8,.75);
            border: 1px solid var(--bdr-2);
            border-radius: 20px;
            backdrop-filter: blur(16px);
            padding: 24px 26px;
            box-shadow: 0 24px 80px rgba(0,0,0,.5), 0 0 0 1px rgba(242,190,48,.06) inset;
            position: relative;
            overflow: hidden;
        }
        .glass-card::before {
            content: '';
            position: absolute;
            top: -60px; right: -60px;
            width: 200px; height: 200px;
            border-radius: 50%;
            background: radial-gradient(circle, rgba(242,190,48,.08) 0%, transparent 70%);
            pointer-events: none;
        }

        .card-header {
            display: flex;
            align-items: center;
            justify-content: space-between;
            margin-bottom: 20px;
        }
        .card-header-title {
            font-family: var(--serif);
            font-size: 15px;
            color: var(--txt-2);
        }
        .live-badge {
            display: flex; align-items: center; gap: 6px;
            font-size: 10.5px; font-weight: 700;
            color: var(--green);
            background: rgba(82,201,139,.12);
            border: 1px solid rgba(82,201,139,.25);
            border-radius: 99px;
            padding: 4px 10px;
        }
        .live-dot {
            width: 6px; height: 6px;
            border-radius: 50%;
            background: var(--green);
            animation: pulse 1.5s infinite;
        }

        .mini-stats {
            display: grid;
            grid-template-columns: repeat(3, 1fr);
            gap: 12px;
            margin-bottom: 20px;
        }
        .mini-stat {
            background: rgba(255,255,255,.03);
            border: 1px solid var(--bdr);
            border-radius: 12px;
            padding: 14px 12px;
            text-align: center;
        }
        .mini-stat-val {
            font-family: var(--serif);
            font-size: 22px;
            line-height: 1;
            margin-bottom: 4px;
        }
        .mini-stat-lbl {
            font-size: 10.5px;
            color: var(--txt-4);
            text-transform: uppercase;
            letter-spacing: .07em;
            font-weight: 700;
        }

        .sem-row {
            margin-bottom: 16px;
        }
        .sem-header {
            display: flex;
            justify-content: space-between;
            font-size: 11px;
            color: var(--txt-4);
            margin-bottom: 8px;
        }
        .sem-bar {
            height: 8px;
            border-radius: 99px;
            overflow: hidden;
            display: flex;
            background: rgba(255,255,255,.04);
        }
        .sem-bar div { height: 100%; border-radius: 99px; }

        .alert-list { display: flex; flex-direction: column; gap: 8px; }
        .alert-row {
            display: flex;
            align-items: center;
            gap: 10px;
            padding: 10px 12px;
            background: rgba(255,255,255,.02);
            border: 1px solid var(--bdr);
            border-radius: 10px;
            font-size: 12.5px;
            color: var(--txt-2);
        }
        .alert-ico-sm {
            width: 28px; height: 28px;
            border-radius: 8px;
            display: flex; align-items: center; justify-content: center;
            font-size: 13px;
            flex-shrink: 0;
        }
        .alert-time { margin-left: auto; font-size: 11px; color: var(--txt-4); }

        /* Bottom card - smaller */
        .glass-card-sm {
            background: rgba(19,16,8,.65);
            border: 1px solid var(--bdr);
            border-radius: 16px;
            backdrop-filter: blur(12px);
            padding: 16px 20px;
            display: flex;
            align-items: center;
            gap: 14px;
        }
        .progress-ring { flex-shrink: 0; }
        .ring-info { flex: 1; }
        .ring-title { font-size: 13px; font-weight: 600; color: var(--txt-1); margin-bottom: 3px; }
        .ring-sub   { font-size: 11.5px; color: var(--txt-4); }

        /* Features strip */
        .features {
            position: relative;
            z-index: 1;
            border-top: 1px solid var(--bdr);
            padding: 48px;
            max-width: 1280px;
            margin: 0 auto;
        }
        .features-title {
            font-size: 11px; font-weight: 700;
            letter-spacing: .12em; text-transform: uppercase;
            color: var(--txt-4);
            text-align: center;
            margin-bottom: 32px;
        }
        .features-grid {
            display: grid;
            grid-template-columns: repeat(6, 1fr);
            gap: 12px;
        }
        .feat-card {
            background: rgba(255,255,255,.02);
            border: 1px solid var(--bdr);
            border-radius: 14px;
            padding: 18px 14px;
            text-align: center;
            transition: all .22s;
        }
        .feat-card:hover {
            border-color: var(--bdr-2);
            background: var(--gold-dim);
            transform: translateY(-3px);
        }
        .feat-icon { font-size: 22px; margin-bottom: 8px; }
        .feat-name { font-size: 12px; font-weight: 600; color: var(--txt-2); }

        /* Keyframes */
        @@keyframes fadeUp   { from { opacity:0; transform:translateY(24px); } to { opacity:1; transform:translateY(0); } }
        @@keyframes fadeDown { from { opacity:0; transform:translateY(-16px); } to { opacity:1; transform:translateY(0); } }
        @@keyframes fadeLeft { from { opacity:0; transform:translateX(32px); } to { opacity:1; transform:translateX(0); } }
        @@keyframes pulse    { 0%,100% { opacity:1; transform:scale(1); } 50% { opacity:.5; transform:scale(.85); } }
        @@keyframes countUp  { from { opacity:0; transform:translateY(8px); } to { opacity:1; transform:translateY(0); } }

        @@media (max-width: 960px) {
            .hero { grid-template-columns: 1fr; padding: 100px 24px 60px; gap: 40px; }
            .hero-right { display: none; }
            .features-grid { grid-template-columns: repeat(3, 1fr); }
            nav { padding: 16px 24px; }
        }
        @@media (max-width: 480px) {
            .features-grid { grid-template-columns: repeat(2, 1fr); }
            .hero-stats { gap: 20px; }
            .features { padding: 32px 24px; }
        }
    </style>
</head>
<body>
    <canvas id="hex-bg"></canvas>

    <!-- NAV -->
    <nav>
        <div class="nav-logo">
            <div class="nav-logo-mark">🐝</div>
            <div class="nav-logo-name">ColmenaEmpresa</div>
        </div>
        <span class="nav-pill">v2.0 · Uruguay</span>
    </nav>

    <!-- HERO -->
    <section class="hero">
        <div class="hero-left">
            <div class="hero-badge">
                <div class="hero-badge-dot"></div>
                Plataforma apícola profesional
            </div>

            <h1>
                Gestioná tu<br>
                <span class="accent">empresa</span><br>
                <span class="line2">apícola.</span>
            </h1>

            <p class="hero-desc">
                Control total de apiarios, colmenas, sanidad, producción y finanzas — todo desde un solo lugar, diseñado para el apicultor profesional.
            </p>

            <div class="hero-cta">
                <a href="@Url.Action("Index", "Home")" class="btn-primary">
                    Ingresar al sistema <span class="arrow">→</span>
                </a>
                <a href="#features" class="btn-ghost">
                    Ver funciones ↓
                </a>
            </div>

            <div class="hero-stats">
                <div class="stat">
                    <span class="stat-n" data-count="148">148</span>
                    <span class="stat-l">Colmenas</span>
                </div>
                <div class="stat-div"></div>
                <div class="stat">
                    <span class="stat-n" data-count="4">4</span>
                    <span class="stat-l">Apiarios</span>
                </div>
                <div class="stat-div"></div>
                <div class="stat">
                    <span class="stat-n">2.4 t</span>
                    <span class="stat-l">Producción</span>
                </div>
                <div class="stat-div"></div>
                <div class="stat">
                    <span class="stat-n" style="color:var(--green)">98%</span>
                    <span class="stat-l">Colmenas sanas</span>
                </div>
            </div>
        </div>

        <!-- PREVIEW CARD -->
        <div class="hero-right">
            <div class="glass-card">
                <div class="card-header">
                    <div class="card-header-title">Dashboard — Vista general</div>
                    <div class="live-badge"><div class="live-dot"></div>En vivo</div>
                </div>

                <div class="mini-stats">
                    <div class="mini-stat">
                        <div class="mini-stat-val" style="color:var(--gold)">148</div>
                        <div class="mini-stat-lbl">Colmenas</div>
                    </div>
                    <div class="mini-stat">
                        <div class="mini-stat-val" style="color:var(--red)">3</div>
                        <div class="mini-stat-lbl">Alertas</div>
                    </div>
                    <div class="mini-stat">
                        <div class="mini-stat-val" style="color:var(--green)">2.4t</div>
                        <div class="mini-stat-lbl">Cosecha</div>
                    </div>
                </div>

                <div class="sem-row">
                    <div class="sem-header">
                        <span>Semáforo sanitario</span>
                        <span style="color:var(--green)">88 al día</span>
                    </div>
                    <div class="sem-bar">
                        <div style="width:59%;background:var(--green)"></div>
                        <div style="width:29%;background:var(--amber)"></div>
                        <div style="width:12%;background:var(--red)"></div>
                    </div>
                </div>

                <div class="alert-list">
                    <div class="alert-row">
                        <div class="alert-ico-sm" style="background:rgba(242,107,107,.15)">⚠</div>
                        <span>La Rinconada — inspección vencida</span>
                        <span class="alert-time">12 días</span>
                    </div>
                    <div class="alert-row">
                        <div class="alert-ico-sm" style="background:rgba(240,168,53,.15)">🔍</div>
                        <span>C-47 — reina no vista</span>
                        <span class="alert-time">3 días</span>
                    </div>
                    <div class="alert-row">
                        <div class="alert-ico-sm" style="background:rgba(82,201,139,.15)">✓</div>
                        <span>Transhumancia completada</span>
                        <span class="alert-time">1 sem.</span>
                    </div>
                </div>
            </div>

            <!-- Bottom mini card -->
            <div class="glass-card-sm">
                <svg class="progress-ring" width="52" height="52" viewBox="0 0 52 52">
                    <circle cx="26" cy="26" r="21" fill="none" stroke="rgba(242,190,48,.12)" stroke-width="5"/>
                    <circle cx="26" cy="26" r="21" fill="none" stroke="#F2BE30" stroke-width="5"
                        stroke-dasharray="131.9" stroke-dashoffset="26" stroke-linecap="round"
                        transform="rotate(-90 26 26)"/>
                    <text x="26" y="30" text-anchor="middle" fill="#F2BE30" font-size="12" font-family="DM Serif Display" font-weight="700">80%</text>
                </svg>
                <div class="ring-info">
                    <div class="ring-title">Inspecciones al día</div>
                    <div class="ring-sub">118 / 148 colmenas revisadas este mes</div>
                </div>
                <span style="font-size:20px">🍯</span>
            </div>
        </div>
    </section>

    <!-- FEATURES -->
    <section class="features" id="features">
        <div class="features-title">Todo lo que necesitás</div>
        <div class="features-grid">
            <div class="feat-card"><div class="feat-icon">📍</div><div class="feat-name">Apiarios</div></div>
            <div class="feat-card"><div class="feat-icon">🏠</div><div class="feat-name">Colmenas</div></div>
            <div class="feat-card"><div class="feat-icon">🔍</div><div class="feat-name">Inspecciones</div></div>
            <div class="feat-card"><div class="feat-icon">🩺</div><div class="feat-name">Sanidad</div></div>
            <div class="feat-card"><div class="feat-icon">🍯</div><div class="feat-name">Producción</div></div>
            <div class="feat-card"><div class="feat-icon">💰</div><div class="feat-name">Finanzas</div></div>
        </div>
    </section>

    <script>
        // Hex background
        (function () {
            const cv = document.getElementById('hex-bg');
            if (!cv) return;
            const cx = cv.getContext('2d');
            const R = 26, GAP = 3;
            let mx = -9999, my = -9999, hexes = [];

            function build() {
                hexes = [];
                const W = (2 * R + GAP) * 0.75, H = (Math.sqrt(3) * R + GAP);
                for (let c = -1; c < Math.ceil(cv.width / W) + 2; c++)
                    for (let r = -1; r < Math.ceil(cv.height / H) + 2; r++)
                        hexes.push({ x: c * W, y: r * H + (c % 2 ? H / 2 : 0), g: 0 });
            }

            function hex(x, y, r) {
                cx.beginPath();
                for (let i = 0; i < 6; i++) {
                    const a = Math.PI / 180 * (60 * i - 30);
                    i ? cx.lineTo(x + r * Math.cos(a), y + r * Math.sin(a))
                      : cx.moveTo(x + r * Math.cos(a), y + r * Math.sin(a));
                }
                cx.closePath();
            }

            function resize() { cv.width = window.innerWidth; cv.height = window.innerHeight; build(); }

            function draw() {
                cx.clearRect(0, 0, cv.width, cv.height);
                hexes.forEach(h => {
                    const d = Math.hypot(mx - h.x, my - h.y);
                    h.g += ((d < 120 ? (1 - d / 120) * 0.7 : 0) - h.g) * 0.12;
                    const a = 0.032 + h.g * 0.6;
                    hex(h.x, h.y, R - 1.5);
                    cx.fillStyle   = `rgba(242,190,48,${(a * .4).toFixed(3)})`;
                    cx.fill();
                    cx.strokeStyle = `rgba(242,190,48,${a.toFixed(3)})`;
                    cx.lineWidth   = h.g > 0.06 ? 1.3 : 0.6;
                    cx.stroke();
                });
                requestAnimationFrame(draw);
            }

            window.addEventListener('resize', resize);
            window.addEventListener('mousemove', e => { mx = e.clientX; my = e.clientY; });
            resize(); draw();
        })();

        // Smooth scroll
        document.querySelector('a[href="#features"]')?.addEventListener('click', e => {
            e.preventDefault();
            document.getElementById('features')?.scrollIntoView({ behavior: 'smooth' });
        });
    </script>
</body>
</html>
