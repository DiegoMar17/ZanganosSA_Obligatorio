@model ColmenaEmpresa.Models.DashboardViewModel
@{
    ViewData["Title"] = "Dashboard";
    ViewData["Subtitle"] = Model.EsAdmin ? "Vista general de tu operación apícola" : "Vista general de tu sector asignado";
}

@section Actions {
    @if (Model.EsAdmin)
    {
        <a class="btn btn-primary btn-sm" asp-controller="Colmenas" asp-action="Crear">+ Nueva colmena</a>
    }
}

<div class="g4 mb-6">
    <div class="stat-card">
        <div class="stat-card-accent" style="background:var(--gold-dim)">🐝</div>
        <div class="stat-lbl">Colmenas activas</div>
        <div class="stat-val c-gold">@Model.TotalColmenas</div>
        <div class="stat-meta">@(Model.ColmenasNuevasMes > 0 ? $"↑ {Model.ColmenasNuevasMes} este mes" : "Sin altas este mes")</div>
    </div>
    <div class="stat-card">
        <div class="stat-card-accent" style="background:var(--red-bg)">⚠</div>
        <div class="stat-lbl">Inspecciones pend.</div>
        <div class="stat-val c-red">@Model.InspeccionesPendientes</div>
        <div class="stat-meta">Sin completar</div>
    </div>
    <div class="stat-card">
        <div class="stat-card-accent" style="background:var(--amber-bg)">🍯</div>
        <div class="stat-lbl">Cosecha total</div>
        <div class="stat-val c-amber">@Model.CosechaTotal</div>
        <div class="stat-meta">Temporada 2025–26</div>
    </div>
    <div class="stat-card">
        <div class="stat-card-accent" style="background:var(--green-bg)">📍</div>
        <div class="stat-lbl">Apiarios</div>
        <div class="stat-val c-green">@Model.TotalApiarios</div>
        <div class="stat-meta">@(Model.EnTranshumancia > 0 ? $"{Model.EnTranshumancia} en transhumancia" : "Ninguno en traslado")</div>
    </div>
</div>

<div class="g2 mb-6">
    <div class="card">
        <div class="card-hd"><div class="card-title">Alertas activas</div><span class="pill p-red">@Model.Alertas.Count(a => a.Tipo == "red") urgentes</span></div>
        @foreach (var alerta in Model.Alertas)
        {
            <div class="alert-item">
                <div class="alert-ico a-@alerta.Tipo">@(alerta.Tipo == "red" ? "⚠" : alerta.Tipo == "amber" ? "🔍" : "✓")</div>
                <div class="alert-body">
                    <div class="alert-title">@alerta.Titulo</div>
                    <div class="alert-time">@alerta.Tiempo</div>
                </div>
            </div>
        }
    </div>
    <div class="card">
        <div class="card-hd"><div class="card-title">Producción mensual</div><span class="pill p-ghost">kg</span></div>
        @if (!Model.ProduccionMensual.Any())
        {
            <div style="padding:32px;text-align:center;color:var(--txt-4);font-size:13px">Sin cosechas registradas todavía.</div>
        }
        else
        {
            <div class="bars">
                @foreach (var item in Model.ProduccionMensual)
                {
                    <div class="bar" style="height:@(item.PorcentajeAlto)%;background:@(item.PorcentajeAlto >= 80 ? "var(--gold)" : "var(--bg-3)")" title="@item.Mes: @item.Kg kg"></div>
                }
            </div>
            <div class="bar-lbls">
                @foreach (var item in Model.ProduccionMensual)
                {
                    <div class="bar-lbl">@item.Mes</div>
                }
            </div>
        }
    </div>
</div>

<div class="card">
    <div class="card-hd"><div class="card-title">Semáforo sanitario</div><span style="font-size:12px;color:var(--txt-4)">@Model.TotalColmenas colmenas totales</span></div>
    <div style="display:grid;grid-template-columns:repeat(3,1fr);gap:10px;margin-bottom:12px">
        <div class="sem-leg"><div class="sem-dot" style="background:var(--green)"></div>Verde — al día (@Model.ColmenasVerde)</div>
        <div class="sem-leg"><div class="sem-dot" style="background:var(--amber)"></div>Amarillo — pronto (@Model.ColmenasAmarillo)</div>
        <div class="sem-leg"><div class="sem-dot" style="background:var(--red)"></div>Rojo — vencida (@Model.ColmenasRojo)</div>
    </div>
    <div class="sem-track">
        @if (Model.TotalColmenas > 0)
        {
            <div style="width:@(Model.ColmenasVerde * 100 / Model.TotalColmenas)%;background:var(--green)"></div>
            <div style="width:@(Model.ColmenasAmarillo * 100 / Model.TotalColmenas)%;background:var(--amber)"></div>
            <div style="width:@(Model.ColmenasRojo * 100 / Model.TotalColmenas)%;background:var(--red)"></div>
        }
        else
        {
            <div style="width:100%;background:var(--surface-2)"></div>
        }
    </div>
</div>

@if (Model.EsAdmin)
{
    <div class="g4 mb-6" style="margin-top:24px">
        <div class="stat-card">
            <div class="stat-card-accent" style="background:var(--gold-dim)">📋</div>
            <div class="stat-lbl">Tareas pendientes</div>
            <div class="stat-val c-gold">@Model.TareasPendientesCount</div>
            <div class="stat-meta">En todo el sistema</div>
        </div>
        <div class="stat-card">
            <div class="stat-card-accent" style="background:var(--green-bg)">👷</div>
            <div class="stat-lbl">Empleados con acceso</div>
            <div class="stat-val c-green">@Model.EmpleadosActivos</div>
            <div class="stat-meta">PIN habilitado</div>
        </div>
        <div class="stat-card">
            <div class="stat-card-accent" style="background:var(--red-bg)">🧪</div>
            <div class="stat-lbl">Controles vencidos</div>
            <div class="stat-val c-red">@Model.ControlesVencidos</div>
            <div class="stat-meta">+30 días en tratamiento</div>
        </div>
        <div class="stat-card">
            <div class="stat-card-accent" style="background:var(--amber-bg)">📜</div>
            <div class="stat-lbl">Auditoría</div>
            <div class="stat-val c-amber">@Model.UltimosAuditoria.Count</div>
            <div class="stat-meta"><a asp-controller="Auditoria" asp-action="Index" style="color:var(--txt-3)">Ver registro completo →</a></div>
        </div>
    </div>

    <div class="card">
        <div class="card-hd"><div class="card-title">Últimos registros de auditoría</div><a asp-controller="Auditoria" asp-action="Index" class="pill p-ghost">Ver todo</a></div>
        @if (!Model.UltimosAuditoria.Any())
        {
            <div style="padding:32px;text-align:center;color:var(--txt-4);font-size:13px">Sin actividad registrada todavía.</div>
        }
        else
        {
            <div class="tbl-wrap">
                <table>
                    <thead><tr><th>Fecha</th><th>Usuario</th><th>Acción</th><th>Tabla</th><th>Detalle</th></tr></thead>
                    <tbody>
                        @foreach (var a in Model.UltimosAuditoria)
                        {
                            <tr>
                                <td class="td-1">@a.FechaHora.ToString("dd MMM HH:mm")</td>
                                <td>@a.NombreUsuario</td>
                                <td><span class="pill @(a.Accion == "CREATE" ? "p-green" : a.Accion == "DELETE" ? "p-red" : "p-amber")">@a.Accion</span></td>
                                <td>@a.Tabla</td>
                                <td>@a.Detalle</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>
}
else
{
    <div class="card" style="margin-top:24px">
        <div class="card-hd"><div class="card-title">Mis tareas</div><a asp-controller="Planificacion" asp-action="Index" class="pill p-ghost">Ver todas</a></div>
        <div style="padding:20px 4px">
            <div class="stat-lbl">Pendientes asignadas a mí</div>
            <div class="stat-val c-gold">@Model.TareasPendientesCount</div>
        </div>
    </div>
}
