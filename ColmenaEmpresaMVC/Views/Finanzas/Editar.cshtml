@model ColmenaEmpresa.Models.RegistroFinanciero
@{
    ViewData["Title"] = "Editar Registro";
    ViewData["Subtitle"] = "Modificar movimiento financiero";
}

<div class="form-wrap">
    <div class="form-title">💰 Editar registro financiero</div>
    <div class="form-desc">Modificá los datos del movimiento registrado.</div>

    <form asp-action="Editar" asp-route-id="@Model.Id" method="post">
        <input type="hidden" asp-for="Id" />
        <div asp-validation-summary="ModelOnly" class="fhint mb-4" style="color:var(--red);background:var(--red-bg);border-radius:var(--r-sm);padding:10px 14px"></div>

        <div class="fs">Tipo de movimiento</div>
        <div class="radio-row mb-6">
            <label class="radio-card @(Model.TipoMovimiento == "ingreso" ? "sel" : "")" style="border-color:var(--green-bdr);background:var(--green-bg);color:var(--green)">
                <input type="radio" asp-for="TipoMovimiento" value="ingreso"> ↑ Ingreso
            </label>
            <label class="radio-card @(Model.TipoMovimiento == "gasto" ? "sel" : "")" style="border-color:var(--red-bdr);color:var(--red)">
                <input type="radio" asp-for="TipoMovimiento" value="gasto"> ↓ Gasto
            </label>
            <label class="radio-card @(Model.TipoMovimiento == "inversion" ? "sel" : "")" style="border-color:var(--amber-bdr);color:var(--amber)">
                <input type="radio" asp-for="TipoMovimiento" value="inversion"> ◆ Inversión
            </label>
        </div>

        <div class="fg">
            <div class="fgrp">
                <label class="flbl">Categoría <span class="req">*</span></label>
                <select asp-for="Categoria" class="fc">
                    <option>Venta de miel</option>
                    <option>Venta de polen</option>
                    <option>Insumos apícolas</option>
                    <option>Equipamiento</option>
                </select>
                <span asp-validation-for="Categoria" class="fhint" style="color:var(--red)"></span>
            </div>
            <div class="fgrp">
                <label class="flbl">Monto <span class="req">*</span></label>
                <input asp-for="Monto" class="fc" type="number" step="0.01" style="color:var(--green);font-weight:700;font-size:16px">
                <span asp-validation-for="Monto" class="fhint" style="color:var(--red)"></span>
            </div>
            <div class="fgrp">
                <label class="flbl">Fecha <span class="req">*</span></label>
                <input asp-for="Fecha" class="fc" type="date">
                <span asp-validation-for="Fecha" class="fhint" style="color:var(--red)"></span>
            </div>
            <div class="fgrp">
                <label class="flbl">Apiario</label>
                <select asp-for="ApiarioNombre" class="fc">
                    <option value="General">General</option>
                    <option>Monte Olivo</option>
                    <option>La Rinconada</option>
                </select>
            </div>
            <div class="fgrp fg-full">
                <label class="flbl">Descripción <span class="req">*</span></label>
                <textarea asp-for="Descripcion" class="fc" placeholder="Detalles del movimiento…"></textarea>
                <span asp-validation-for="Descripcion" class="fhint" style="color:var(--red)"></span>
            </div>
        </div>

        <div class="form-footer">
            <a asp-action="Index" class="btn">Cancelar</a>
            <button type="submit" class="btn btn-primary">Guardar cambios</button>
        </div>
    </form>
</div>

@section Scripts {
    @await Html.PartialAsync("_ValidationScriptsPartial")
}
