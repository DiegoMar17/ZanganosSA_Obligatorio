@model ColmenaEmpresa.Models.RegistroFinanciero
@{
    ViewData["Title"] = "Registro Financiero";
    ViewData["Subtitle"] = "Ingresá el movimiento";
}

<div class="form-wrap">
    <div class="form-title">💰 Registro financiero</div>
    <div class="form-desc">Registrá ingresos, gastos e inversiones de tu operación.</div>

    <form asp-action="Crear" method="post">
        <div class="fs">Tipo de movimiento</div>
        <div class="radio-row mb-6">
            <label class="radio-card @(Model.TipoMovimiento == "ingreso" ? "sel" : "")" style="border-color:var(--green-bdr);background:var(--green-bg);color:var(--green)">
                <input type="radio" asp-for="TipoMovimiento" value="ingreso"> ↑ Ingreso
            </label>
            <label class="radio-card @(Model.TipoMovimiento == "gasto" ? "sel" : "")" style="border-color:var(--red-bdr);color:var(--red)">
                <input type="radio" asp-for="TipoMovimiento" value="gasto"> ↓ Gasto
            </label>
            <label class="radio-card @(Model.TipoMovimiento == "inversion" ? "sel" : "")" style="border-color:var(--amber-bdr);color:var(--amber)">
                <input type="radio" asp-for="TipoMovimiento" value="inversion"> ◆ Inversión
            </label>
        </div>

        <div class="fg">
            <div class="fgrp">
                <label class="flbl">Categoría <span class="req">*</span></label>
                <select asp-for="Categoria" class="fc" required>
                    <option>Venta de miel</option>
                    <option>Venta de polen</option>
                    <option>Insumos apícolas</option>
                    <option>Equipamiento</option>
                </select>
            </div>
            <div class="fgrp">
                <label class="flbl">Monto <span class="req">*</span></label>
                <input asp-for="Monto" class="fc" type="number" step="0.01" style="color:var(--green);font-weight:700;font-size:16px" required>
            </div>
            <div class="fgrp">
                <label class="flbl">Fecha <span class="req">*</span></label>
                <input asp-for="Fecha" class="fc" type="date" required>
            </div>
            <div class="fgrp">
                <label class="flbl">Apiario</label>
                <select asp-for="ApiarioNombre" class="fc">
                    <option value="General">General</option>
                    <option>Monte Olivo</option>
                    <option>La Rinconada</option>
                </select>
            </div>
            <div class="fgrp fg-full">
                <label class="flbl">Descripción</label>
                <textarea asp-for="Descripcion" class="fc" placeholder="Detalles del movimiento…"></textarea>
            </div>
        </div>

        <div class="form-footer">
            <a asp-action="Index" class="btn">Cancelar</a>
            <button type="submit" class="btn btn-primary">Guardar registro</button>
        </div>
    </form>
</div>
