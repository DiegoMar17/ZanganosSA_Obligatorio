@model ColmenaEmpresa.Models.PagedResult<ColmenaEmpresa.Models.Auditoria>
@{
    ViewData["Title"]    = "Auditoría";
    ViewData["Subtitle"] = "Historial completo de acciones del sistema";
    var usuarios   = ViewBag.Usuarios as List<ColmenaEmpresa.Models.ApplicationUser> ?? new();
    var tablas     = ViewBag.Tablas   as List<string> ?? new();
    var filtroUser = ViewBag.FiltroUserId as string;
    var filtroAcc  = ViewBag.FiltroAccion as string;
    var filtroTabl = ViewBag.FiltroTabla  as string;
    var desde      = ViewBag.FiltroDesde  as DateTime?;
    var hasta      = ViewBag.FiltroHasta  as DateTime?;
}

@section Actions {
    <a asp-action="HistorialAccesos" class="btn-action-sm">🔐 Historial accesos</a>
}

<form method="get" style="margin-bottom:20px;display:flex;gap:10px;flex-wrap:wrap;align-items:flex-end">
    <div class="fgrp-h">
        <label class="flbl">Empleado</label>
        <select name="userId" class="fc-sm">
            <option value="">Todos</option>
            @foreach (var u in usuarios)
            {
                <option value="@u.Id" selected="@(filtroUser == u.Id ? "selected" : null)">@u.NombreCompleto</option>
            }
        </select>
    </div>
    <div class="fgrp-h">
        <label class="flbl">Tabla</label>
        <select name="tabla" class="fc-sm">
            <option value="">Todas</option>
            @foreach (var t in tablas)
            {
                <option value="@t" selected="@(filtroTabl == t ? "selected" : null)">@t</option>
            }
        </select>
    </div>
    <div class="fgrp-h">
        <label class="flbl">Desde</label>
        <input type="date" name="desde" class="fc-sm" value="@(desde?.ToString("yyyy-MM-dd"))">
    </div>
    <div class="fgrp-h">
        <label class="flbl">Hasta</label>
        <input type="date" name="hasta" class="fc-sm" value="@(hasta?.ToString("yyyy-MM-dd"))">
    </div>
    <button type="submit" class="btn-action-sm">Filtrar</button>
    <a asp-action="Index" class="btn-sm-link">✕ Limpiar</a>
</form>

<div class="tbl-wrap">
    <table class="tbl">
        <thead>
            <tr>
                <th>Fecha / Hora</th>
                <th>Usuario</th>
                <th>Acción</th>
                <th>Tabla</th>
                <th>Detalle</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var a in Model.Items)
            {
                <tr>
                    <td style="color:var(--txt-3);font-size:13px;white-space:nowrap">@a.FechaHora.ToString("dd/MM/yy HH:mm:ss")</td>
                    <td>
                        <strong style="font-size:13px">@a.NombreUsuario</strong>
                    </td>
                    <td>
                        @{
                            var (accionColor, accionLabel) = a.Accion switch {
                                "CREATE" => ("p-g", "➕ Crear"),
                                "UPDATE" => ("p-amber", "✏ Editar"),
                                "DELETE" => ("p-r", "🗑 Eliminar"),
                                _ => ("", a.Accion)
                            };
                        }
                        <span class="pill @accionColor" style="font-size:11px">@accionLabel</span>
                    </td>
                    <td style="color:var(--txt-2);font-size:13px">@a.Tabla</td>
                    <td style="color:var(--txt-4);font-size:12px;max-width:200px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap" title="@a.Detalle">@a.Detalle</td>
                </tr>
            }
            @if (!Model.Items.Any())
            {
                <tr><td colspan="5" style="text-align:center;color:var(--txt-4);padding:32px">Sin registros de auditoría aún.</td></tr>
            }
        </tbody>
    </table>
</div>

@await Html.PartialAsync("_Pagination", Model)

<style>
.fgrp-h { display:flex; flex-direction:column; gap:5px; }
.flbl { font-size:12px; font-weight:600; color:var(--txt-3); }
.fc-sm { background:var(--bg-1); border:1px solid var(--bdr); border-radius:8px; color:var(--txt-1); font-size:13px; padding:8px 10px; outline:none; min-width:140px; }
.fc-sm:focus { border-color:var(--gold); }
.btn-action-sm { padding:9px 16px; background:var(--gold); color:#0C0A07; font-weight:700; border:none; border-radius:9px; cursor:pointer; font-size:13px; text-decoration:none; display:inline-block; }
.btn-sm-link { padding:9px 12px; border:1px solid var(--bdr); border-radius:9px; color:var(--txt-3); font-size:13px; text-decoration:none; }
</style>
