@model ColmenaEmpresa.Models.PagedResult<ColmenaEmpresa.Models.Colmena>
@{
    ViewData["Title"] = "Colmenas";
    var resumen = ViewBag.Resumen;
    ViewData["Subtitle"] = resumen.Total + " colmenas activas";
}

@section Actions {
    <a class="btn btn-primary btn-sm" asp-action="Crear">+ Nueva colmena</a>
}

<div class="g4 mb-6">
    <div class="stat-card"><div class="stat-lbl">Total colmenas</div><div class="stat-val c-gold">@resumen.Total</div></div>
    <div class="stat-card"><div class="stat-lbl">En producción</div><div class="stat-val c-green">@resumen.EnProduccion</div></div>
    <div class="stat-card"><div class="stat-lbl">En tratamiento</div><div class="stat-val c-amber">@resumen.EnTratamiento</div></div>
    <div class="stat-card"><div class="stat-lbl">Sin reina</div><div class="stat-val c-red">@resumen.SinReina</div></div>
</div>

<div class="flex-between mb-4">
    <form method="get" asp-action="Index" style="display:flex;gap:8px;align-items:center">
        <input type="text" name="q" value="@Model.Q" class="fc" placeholder="Buscar por código, apiario…" style="max-width:280px">
        <button type="submit" class="btn btn-sm">Buscar</button>
        @if (!string.IsNullOrWhiteSpace(Model.Q))
        {
            <a class="btn btn-sm" asp-action="Index">✕ Limpiar</a>
        }
    </form>
</div>

<div class="tbl-wrap">
    <table>
        <thead>
            <tr>
                <th>Código</th>
                <th>Apiario</th>
                <th>Asignada a</th>
                <th>Última visita</th>
                <th>Reina</th>
                <th>Estado</th>
                <th>Alzas</th>
                <th></th>
            </tr>
        </thead>
        <tbody>
            @if (!Model.Items.Any())
            {
                <tr><td colspan="8" style="text-align:center;color:var(--txt-4);padding:28px">Sin resultados.</td></tr>
            }
            @foreach (var item in Model.Items)
            {
                <tr>
                    <td class="td-1">@item.Codigo</td>
                    <td>@item.Apiario?.Nombre</td>
                    <td>
                        @if (!string.IsNullOrEmpty(item.AsignadoAId))
                        {
                            <span class="pill p-ghost" style="font-size:11px">👷 @item.AsignadoA?.NombreCompleto</span>
                        }
                        else
                        {
                            <span style="color:var(--txt-4);font-size:12px">Sin asignar</span>
                        }
                    </td>
                    <td>@(item.UltimaVisita.HasValue ? "Hace " + (DateTime.Now - item.UltimaVisita.Value).Days + " días" : "—")</td>
                    <td>
                        @if (item.EstadoReina == "vista")      { <span style="color:var(--green)">✓ Vista</span> }
                        else if (item.EstadoReina == "no_vista"){ <span style="color:var(--amber)">? No vista</span> }
                        else                                    { <span style="color:var(--red)">✗ Ausente</span> }
                    </td>
                    <td>
                        @{
                            var pill = item.EstadoSemaforo switch {
                                "rojo"     => "p-red",
                                "amarillo" => "p-amber",
                                "viaje"    => "p-blue",
                                _          => "p-green"
                            };
                            var txt = item.EstadoSemaforo switch {
                                "rojo"     => "Crítico",
                                "amarillo" => "Alerta",
                                "viaje"    => "En viaje",
                                _          => "Saludable"
                            };
                        }
                        <span class="pill @pill">@txt</span>
                    </td>
                    <td class="td-1">@item.CantidadAlzas</td>
                    <td style="display:flex;gap:6px">
                        @if (User.IsInRole("ADMIN"))
                        {
                            <a class="btn btn-xs btn-icon" asp-action="Editar" asp-route-id="@item.Id" title="Editar">✏</a>
                            <form asp-action="Eliminar" asp-route-id="@item.Id" method="post" style="display:inline" onsubmit="return confirm('¿Eliminar la colmena @item.Codigo?')">
                                @Html.AntiForgeryToken()
                                <button type="submit" class="btn btn-xs btn-icon" style="color:var(--red)" title="Eliminar">🗑</button>
                            </form>
                        }
                    </td>
                </tr>
            }
        </tbody>
    </table>
    @await Html.PartialAsync("_Pagination", Model)
</div>
