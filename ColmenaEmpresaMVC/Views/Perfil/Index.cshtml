@model ColmenaEmpresa.Models.ApplicationUser
@{
    ViewData["Title"] = "Mi Perfil";
    ViewData["Subtitle"] = "Datos de tu cuenta";
}

<div class="g2">
    <!-- Tarjeta de usuario -->
    <div>
        <div class="card mb-4" style="text-align:center;padding:32px 24px">
            <div style="width:72px;height:72px;border-radius:50%;background:var(--gold-dim);border:2px solid var(--bdr-2);display:flex;align-items:center;justify-content:center;font-size:32px;margin:0 auto 16px">👨‍🌾</div>
            <div style="font-family:var(--serif);font-size:20px;color:var(--txt-1);margin-bottom:4px">
                @(string.IsNullOrEmpty(Model?.NombreCompleto) ? Model?.Email : Model?.NombreCompleto)
            </div>
            <div style="font-size:13px;color:var(--txt-4);margin-bottom:8px">@Model?.Email</div>
            <div style="display:flex;gap:6px;justify-content:center;margin-bottom:20px;flex-wrap:wrap">
                <span class="pill @(ViewBag.EsAdmin ? "p-amber" : "p-blue")">@(ViewBag.EsAdmin ? "👑 ADMIN" : "🔑 EMPLEADO")</span>
                @if (!ViewBag.EsAdmin)
                {
                    <span class="pill p-ghost">@(ViewBag.SectorNombre ?? "Sin sector asignado")</span>
                    <span class="pill @(ViewBag.PinActivo ? "p-green" : "p-red")">@(ViewBag.TienePin ? (ViewBag.PinActivo ? "PIN activo" : "PIN revocado") : "Sin PIN")</span>
                }
            </div>
            <div class="g4" style="gap:8px">
                <div style="text-align:center">
                    <div style="font-family:var(--serif);font-size:22px;color:var(--gold)">@ViewBag.TotalApiarios</div>
                    <div style="font-size:11px;color:var(--txt-4)">Apiarios</div>
                </div>
                <div style="text-align:center">
                    <div style="font-family:var(--serif);font-size:22px;color:var(--gold)">@ViewBag.TotalColmenas</div>
                    <div style="font-size:11px;color:var(--txt-4)">Colmenas</div>
                </div>
                <div style="text-align:center">
                    <div style="font-family:var(--serif);font-size:22px;color:var(--gold)">@ViewBag.TotalCosechas</div>
                    <div style="font-size:11px;color:var(--txt-4)">Cosechas</div>
                </div>
                <div style="text-align:center">
                    <div style="font-family:var(--serif);font-size:22px;color:var(--gold)">@ViewBag.CosechaTotal t</div>
                    <div style="font-size:11px;color:var(--txt-4)">Producción</div>
                </div>
            </div>
        </div>

        <!-- Preferencias -->
        <div class="card">
            <div class="card-hd"><div class="card-title">Preferencias</div></div>
            <div style="display:flex;align-items:center;justify-content:space-between;padding:12px 0;border-bottom:1px solid var(--surface)">
                <div>
                    <div style="font-size:13.5px;font-weight:600;color:var(--txt-1)">Tema de la interfaz</div>
                    <div style="font-size:12px;color:var(--txt-4)">Oscuro o claro</div>
                </div>
                <button class="btn btn-sm" onclick="document.getElementById('theme-btn').click()">Cambiar tema</button>
            </div>
            <div style="display:flex;align-items:center;justify-content:space-between;padding:12px 0">
                <div>
                    <div style="font-size:13.5px;font-weight:600;color:var(--txt-1)">Idioma</div>
                    <div style="font-size:12px;color:var(--txt-4)">Español (Uruguay)</div>
                </div>
                <span class="pill p-ghost">es-UY</span>
            </div>
        </div>
    </div>

    <!-- Formularios -->
    <div>
        <!-- Datos personales -->
        <div class="card mb-4">
            <div class="card-hd"><div class="card-title">Datos personales</div></div>
            <form asp-action="ActualizarDatos" method="post">
                @Html.AntiForgeryToken()
                <div class="fg mb-4">
                    <div class="fgrp">
                        <label class="flbl">Nombre completo</label>
                        <input type="text" name="nombreCompleto" class="fc" value="@Model?.NombreCompleto" placeholder="Tu nombre completo">
                    </div>
                    <div class="fgrp">
                        <label class="flbl">Correo electrónico</label>
                        <input type="email" name="email" class="fc" value="@Model?.Email" required>
                    </div>
                </div>
                <button type="submit" class="btn btn-primary btn-sm">Guardar cambios</button>
            </form>
        </div>

        <!-- Cambiar contraseña -->
        <div class="card mb-4">
            <div class="card-hd"><div class="card-title">Cambiar contraseña</div></div>
            <form asp-action="CambiarPassword" method="post">
                @Html.AntiForgeryToken()
                <div class="fg mb-4">
                    <div class="fgrp fg-full">
                        <label class="flbl">Contraseña actual</label>
                        <input type="password" name="passwordActual" class="fc" placeholder="••••••••" required>
                    </div>
                    <div class="fgrp">
                        <label class="flbl">Nueva contraseña</label>
                        <input type="password" name="passwordNuevo" class="fc" placeholder="Mínimo 6 caracteres" required>
                    </div>
                    <div class="fgrp">
                        <label class="flbl">Confirmar contraseña</label>
                        <input type="password" name="passwordConfirm" class="fc" placeholder="Repetí la contraseña" required>
                    </div>
                </div>
                <button type="submit" class="btn btn-primary btn-sm">Cambiar contraseña</button>
            </form>
        </div>

        <!-- Exportar datos -->
        <div class="card">
            <div class="card-hd">
                <div class="card-title">Exportar datos</div>
            </div>
            <p style="font-size:13px;color:var(--txt-3);margin-bottom:16px">
                Descargá tus registros en formato CSV para abrir en Excel.
            </p>
            <div style="display:flex;gap:10px">
                @if (ViewBag.EsAdmin)
                {
                    <a class="btn btn-sm" asp-controller="Finanzas" asp-action="ExportarCsv">⬇ Finanzas CSV</a>
                }
                <a class="btn btn-sm" asp-controller="Produccion" asp-action="ExportarCsv">⬇ Producción CSV</a>
            </div>
        </div>
    </div>
</div>
