@model ErrorViewModel
@{
    ViewData["Title"] = Model.Is404 ? "Página no encontrada" : "Error";
    ViewData["Subtitle"] = Model.Is404 ? "404" : "Algo salió mal";
    var icon  = Model.Is404 ? "🔍" : "⚠️";
    var title = Model.Is404 ? "Página no encontrada" : "Ocurrió un error";
    var msg   = Model.Is404
        ? "La página que buscás no existe o fue movida."
        : "No pudimos procesar tu solicitud. Probá de nuevo en unos momentos o volvé al inicio.";
}

<div class="card" style="max-width:560px;margin:40px auto;text-align:center;padding:40px 32px">
    <div style="font-size:48px;margin-bottom:16px">@icon</div>
    @if (Model.StatusCode.HasValue)
    {
        <div style="font-size:64px;font-weight:700;color:var(--txt-4);line-height:1;margin-bottom:8px">@Model.StatusCode</div>
    }
    <div class="card-title" style="font-size:22px;margin-bottom:8px">@title</div>
    <p style="font-size:14px;color:var(--txt-3);line-height:1.6;margin-bottom:24px">@msg</p>

    @if (Model.ShowRequestId && !Model.Is404)
    {
        <div style="font-size:12px;color:var(--txt-4);margin-bottom:24px">
            Código de referencia: <code style="color:var(--txt-2)">@Model.RequestId</code>
        </div>
    }

    <a class="btn btn-primary btn-sm" asp-controller="Home" asp-action="Index">← Volver al inicio</a>
</div>
