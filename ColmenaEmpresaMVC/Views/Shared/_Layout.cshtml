@using Microsoft.EntityFrameworkCore
@inject ColmenaEmpresa.Data.AppDbContext _db
@inject Microsoft.AspNetCore.Identity.UserManager<ColmenaEmpresa.Models.ApplicationUser> _userMgr
@{
    var esAdmin   = User.IsInRole("ADMIN");
    var currentUserId = _userMgr.GetUserId(User);
    var rolLabel  = esAdmin ? "Administrador" : "Empleado";
    var rolEmoji  = esAdmin ? "👑" : "👷";
    var tareasUsuario = esAdmin
        ? 0
        : _db.Tareas.Count(t => !t.Completada && t.AsignadoAId == currentUserId);
    int? sectorId = esAdmin ? null : _userMgr.Users.Where(u => u.Id == currentUserId).Select(u => u.ApiarioAsignadoId).FirstOrDefault();
    var apiariosCount = esAdmin ? _db.Apiarios.Count() : (sectorId.HasValue ? 1 : 0);
    var inspeccionesPendientesQ = esAdmin
        ? _db.Inspecciones.Include(i => i.Apiario).Where(i => i.Estado == "pendiente" || i.Estado == "vencida")
        : _db.Inspecciones.Include(i => i.Apiario).Where(i => (i.Estado == "pendiente" || i.Estado == "vencida") && sectorId.HasValue && i.ApiarioId == sectorId.Value);
    var colmenasRojoQ = esAdmin
        ? _db.Colmenas.Include(c => c.Apiario).Where(c => c.EstadoSemaforo == "rojo")
        : _db.Colmenas.Include(c => c.Apiario).Where(c => c.EstadoSemaforo == "rojo" && sectorId.HasValue && c.ApiarioId == sectorId.Value);
}
<!DOCTYPE html>
<html lang="es" data-theme="dark">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - ZanganosSA</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Fraunces:ital,opsz,wght@0,9..144,300;0,9..144,400;0,9..144,500;0,9..144,600;0,9..144,700;1,9..144,400;1,9..144,600&family=Plus+Jakarta+Sans:ital,wght@0,300;0,400;0,500;0,600;0,700;1,400&display=swap" rel="stylesheet">
    <script>document.documentElement.setAttribute('data-theme', localStorage.getItem('theme') || 'dark');</script>
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>
    <canvas id="hex-bg"></canvas>

    <aside class="sidebar">
        <div class="sb-logo">
            <div class="sb-logo-mark">🐝</div>
            <div class="sb-logo-text">
                <div class="sb-logo-name">ZanganosSA</div>
                <div class="sb-logo-tagline">Gestión apícola</div>
            </div>
        </div>

        <nav class="sb-nav">
            <div class="sb-group-label">Principal</div>
            <a class="sb-item @(ViewContext.RouteData.Values["controller"]?.ToString() == "Home" ? "active" : "")" asp-controller="Home" asp-action="Index">
                <span class="sb-ico">◈</span><span class="sb-label">Dashboard</span>
            </a>
            <a class="sb-item @(ViewContext.RouteData.Values["controller"]?.ToString() == "Apiarios" ? "active" : "")" asp-controller="Apiarios" asp-action="Index">
                <span class="sb-ico">📍</span><span class="sb-label">Apiarios</span><span class="sb-badge sb-badge-g">@apiariosCount</span>
            </a>
            <a class="sb-item @(ViewContext.RouteData.Values["controller"]?.ToString() == "Colmenas" ? "active" : "")" asp-controller="Colmenas" asp-action="Index">
                <span class="sb-ico">🏠</span><span class="sb-label">Colmenas</span>
            </a>

            <div class="sb-group-label">Gestión</div>
            <a class="sb-item @(ViewContext.RouteData.Values["controller"]?.ToString() == "Inspecciones" ? "active" : "")" asp-controller="Inspecciones" asp-action="Index">
                <span class="sb-ico">🔍</span><span class="sb-label">Inspecciones</span><span class="sb-badge sb-badge-r">@inspeccionesPendientesQ.Count()</span>
            </a>
            <a class="sb-item @(ViewContext.RouteData.Values["controller"]?.ToString() == "Transhumancia" ? "active" : "")" asp-controller="Transhumancia" asp-action="Index">
                <span class="sb-ico">🚚</span><span class="sb-label">Transhumancia</span>
            </a>
            <a class="sb-item @(ViewContext.RouteData.Values["controller"]?.ToString() == "Sanidad" ? "active" : "")" asp-controller="Sanidad" asp-action="Index">
                <span class="sb-ico">🩺</span><span class="sb-label">Sanidad</span>
            </a>
            <a class="sb-item @(ViewContext.RouteData.Values["controller"]?.ToString() == "Alertas" ? "active" : "")" asp-controller="Alertas" asp-action="Index">
                <span class="sb-ico">🚨</span><span class="sb-label">Alertas</span><span class="sb-badge sb-badge-r">@_db.AlertasComunitarias.Count(a => a.Estado == "activa")</span>
            </a>

            <div class="sb-group-label">Planificación</div>
            <a class="sb-item @(ViewContext.RouteData.Values["controller"]?.ToString() == "Calendario" ? "active" : "")" asp-controller="Calendario" asp-action="Index">
                <span class="sb-ico">📅</span><span class="sb-label">Calendario</span>
            </a>
            <a class="sb-item @(ViewContext.RouteData.Values["controller"]?.ToString() == "Planificacion" ? "active" : "")" asp-controller="Planificacion" asp-action="Index">
                <span class="sb-ico">📋</span><span class="sb-label">Tareas y visitas</span>@if (tareasUsuario > 0) { <span class="sb-badge sb-badge-r">@tareasUsuario</span> }
            </a>

            <div class="sb-group-label">Recursos</div>
            @if (esAdmin)
            {
                <a class="sb-item @(ViewContext.RouteData.Values["controller"]?.ToString() == "Finanzas" ? "active" : "")" asp-controller="Finanzas" asp-action="Index">
                    <span class="sb-ico">💰</span><span class="sb-label">Finanzas</span>
                </a>
            }
            <a class="sb-item @(ViewContext.RouteData.Values["controller"]?.ToString() == "Inventario" ? "active" : "")" asp-controller="Inventario" asp-action="Index">
                <span class="sb-ico">📦</span><span class="sb-label">Inventario</span>
            </a>
            <a class="sb-item @(ViewContext.RouteData.Values["controller"]?.ToString() == "Produccion" ? "active" : "")" asp-controller="Produccion" asp-action="Index">
                <span class="sb-ico">🍯</span><span class="sb-label">Producción</span>
            </a>

            @if (esAdmin)
            {
                <div class="sb-group-label">Administración</div>
                <a class="sb-item @(ViewContext.RouteData.Values["controller"]?.ToString() == "Equipo" ? "active" : "")" asp-controller="Equipo" asp-action="Index">
                    <span class="sb-ico">👥</span><span class="sb-label">Mi equipo</span>
                </a>
                <a class="sb-item @(ViewContext.RouteData.Values["controller"]?.ToString() == "Pin" ? "active" : "")" asp-controller="Pin" asp-action="Index">
                    <span class="sb-ico">🔑</span><span class="sb-label">Gestión de PINs</span>
                </a>
                <a class="sb-item @(ViewContext.RouteData.Values["controller"]?.ToString() == "Auditoria" ? "active" : "")" asp-controller="Auditoria" asp-action="Index">
                    <span class="sb-ico">📝</span><span class="sb-label">Auditoría</span>
                </a>
            }

            <div class="sb-group-label">Sistema</div>
            <a class="sb-item @(ViewContext.RouteData.Values["controller"]?.ToString() == "Perfil" ? "active" : "")" asp-controller="Perfil" asp-action="Index">
                <span class="sb-ico">👤</span><span class="sb-label">Perfil</span>
            </a>
        </nav>

        <div class="sb-footer">
            <div class="sb-avatar">@rolEmoji</div>
            <div>
                <div class="sb-user-name">@User.Identity?.Name?.Split('@')[0]</div>
                <div class="sb-user-role">@rolLabel</div>
            </div>
            <form asp-controller="Account" asp-action="Logout" method="post" style="margin-left:auto">
                @Html.AntiForgeryToken()
                <button type="submit" class="sb-settings-btn" title="Cerrar sesión" style="font-size:16px">⏻</button>
            </form>
        </div>
    </aside>

    <div class="main">
        <div class="topbar">
            <div class="tb-breadcrumb">
                <div class="tb-title">@ViewData["Title"]</div>
                <div class="tb-sub">@ViewData["Subtitle"]</div>
            </div>
            <div class="tb-actions">
                <button class="theme-toggle" id="theme-btn">🌙</button>
                <button class="notif-bell" onclick="toggleNotifPanel()">
                    🔔<span class="notif-dot"></span>
                </button>
                @RenderSection("Actions", required: false)
            </div>
        </div>

        <div class="content">
            @RenderBody()
        </div>
    </div>

    <!-- NOTIF PANEL (slide-in) -->
    <div class="notif-panel" id="notif-panel">
        <div class="np-hd">
            <div class="np-title">Notificaciones</div>
            <span class="pill p-red" style="font-size:10.5px">@(tareasUsuario > 0 ? tareasUsuario : inspeccionesPendientesQ.Count()) nuevas</span>
            <button class="np-close" onclick="toggleNotifPanel()">✕</button>
        </div>
        <div class="np-list">
            @foreach (var c in colmenasRojoQ.Take(3).ToList())
            {
                <div class="np-item unread"><div class="np-ico a-red">⚠</div><div class="np-content"><div class="np-title2">Colmena @c.Codigo en estado crítico</div><div class="np-body">@c.Apiario?.Nombre</div></div></div>
            }
            @foreach (var i in inspeccionesPendientesQ.Take(3).ToList())
            {
                <div class="np-item unread"><div class="np-ico a-amber">🔍</div><div class="np-content"><div class="np-title2">Inspección @i.Estado — @i.Apiario?.Nombre</div><div class="np-body">@i.Fecha.ToString("dd MMM yyyy")</div></div></div>
            }
        </div>
    </div>

    <div class="toast" id="toast-el"><span>✓</span><span id="toast-msg"></span></div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
    @if (TempData["Exito"] != null)
    {
        <script>document.addEventListener('DOMContentLoaded', () => toast(@Html.Raw(System.Text.Json.JsonSerializer.Serialize(TempData["Exito"]!.ToString()))));</script>
    }
    @if (TempData["Error"] != null)
    {
        <script>document.addEventListener('DOMContentLoaded', () => toastError(@Html.Raw(System.Text.Json.JsonSerializer.Serialize(TempData["Error"]!.ToString()))));</script>
    }
</body>
</html>
