@model IEnumerable<ColmenaEmpresa.Models.Cosecha>
@{
    ViewData["Title"] = "Producción";
    ViewData["Subtitle"] = "Cosecha temporada 2024–25";
}

@section Actions {
    <a class="btn btn-primary btn-sm" asp-action="Crear">+ Registrar cosecha</a>
}

<div class="g4 mb-6">
    <div class="stat-card"><div class="stat-lbl">Cosecha total</div><div class="stat-val c-gold">@ViewBag.TotalKg kg</div><div class="stat-meta">Temporada 24–25</div></div>
    <div class="stat-card"><div class="stat-lbl">Mejor apiario</div><div class="stat-val" style="font-family:var(--serif);font-size:18px;color:var(--gold)">@ViewBag.MejorApiario</div><div class="stat-meta">@ViewBag.MejorKg kg</div></div>
    <div class="stat-card"><div class="stat-lbl">Prom. colmena</div><div class="stat-val c-gold">@ViewBag.PromColmena kg</div></div>
    <div class="stat-card"><div class="stat-lbl">vs temporada ant.</div><div class="stat-val c-green">@ViewBag.VariacionPct</div></div>
</div>

<div class="card">
    <div class="card-hd"><div class="card-title">Producción por apiario</div></div>
    @if (!Model.Any())
    {
        <div style="padding:24px;color:var(--txt-4);text-align:center">
            <div style="font-size:32px;margin-bottom:8px">🍯</div>
            <div>Sin cosechas registradas.</div>
            <a class="btn btn-primary btn-sm" asp-action="Crear" style="margin-top:14px;display:inline-block">+ Registrar primera cosecha</a>
        </div>
    }
    else
    {
        var maxPeso = Model.Max(m => m.PesoBruto);
        if (maxPeso == 0) { maxPeso = 1; }
        @foreach (var item in Model)
        {
            <div class="prod-row">
                <div class="prod-name">
                    <div style="font-weight:600;color:var(--txt-1)">@item.ApiarioNombre</div>
                    <div style="font-size:11px;color:var(--txt-4)">@item.Fecha.ToString("dd MMM yyyy")</div>
                </div>
                <div class="prod-bar"><div class="prod-fill" style="width:@(item.PesoBruto * 100 / maxPeso)%;background:var(--gold)"></div></div>
                <div class="prod-val c-gold">@Math.Round(item.PesoNeto, 1) kg</div>
                <a class="btn btn-xs btn-icon" asp-action="Editar" asp-route-id="@item.Id" title="Editar">✏</a>
                <form asp-action="Eliminar" asp-route-id="@item.Id" method="post" style="display:inline" onsubmit="return confirm('¿Eliminar esta cosecha?')">
                    @Html.AntiForgeryToken()
                    <button type="submit" class="btn btn-xs btn-icon" style="color:var(--red)" title="Eliminar">🗑</button>
                </form>
            </div>
        }
    }
</div>
