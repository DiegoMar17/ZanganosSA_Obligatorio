@model ColmenaEmpresa.Models.Apiario
@{
    ViewData["Title"] = "Detalle de Apiario";
    ViewData["Subtitle"] = Model.Nombre;
    var colmenasEnApiario = (IEnumerable<ColmenaEmpresa.Models.Colmena>)ViewBag.Colmenas;
}

@section Actions {
    <a class="btn btn-sm" asp-action="Index">← Volver</a>
    <a class="btn btn-primary btn-sm" asp-controller="Colmenas" asp-action="Crear" asp-route-apiarioId="@Model.Id">+ Agregar colmena</a>
}

<div class="g2 mb-6">
    <div class="card">
        <div class="card-hd">
            <div class="card-title">Información General</div>
            <span class="pill p-@Model.EstadoSemaforo">
                @(Model.EstadoSemaforo == "rojo" ? "Inspección Vencida" :
                  Model.EstadoSemaforo == "amarillo" ? "Visitar Pronto" : "Al Día")
            </span>
        </div>
        <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 16px; margin-top: 10px;">
            <div>
                <div style="font-size:11px;color:var(--txt-4);margin-bottom:3px;text-transform:uppercase;letter-spacing:.07em">Departamento</div>
                <div style="font-size:14px;font-weight:600;color:var(--txt-1)">@Model.Departamento</div>
            </div>
            <div>
                <div style="font-size:11px;color:var(--txt-4);margin-bottom:3px;text-transform:uppercase;letter-spacing:.07em">Coordenadas</div>
                <div style="font-size:14px;font-weight:600;color:var(--txt-1)">@Model.Ubicacion</div>
            </div>
            <div>
                <div style="font-size:11px;color:var(--txt-4);margin-bottom:3px;text-transform:uppercase;letter-spacing:.07em">Flora predominante</div>
                <div style="font-size:14px;font-weight:600;color:var(--txt-1)">@Model.Flora</div>
            </div>
            <div>
                <div style="font-size:11px;color:var(--txt-4);margin-bottom:3px;text-transform:uppercase;letter-spacing:.07em">Acceso</div>
                <div style="font-size:14px;font-weight:600;color:var(--txt-1)">@Model.Acceso</div>
            </div>
            <div>
                <div style="font-size:11px;color:var(--txt-4);margin-bottom:3px;text-transform:uppercase;letter-spacing:.07em">Capacidad Máxima</div>
                <div style="font-size:14px;font-weight:600;color:var(--txt-1)">@Model.CapacidadColmenas colmenas</div>
            </div>
            <div>
                <div style="font-size:11px;color:var(--txt-4);margin-bottom:3px;text-transform:uppercase;letter-spacing:.07em">Ocupación Actual</div>
                <div style="font-size:14px;font-weight:600;color:var(--txt-1)">@colmenasEnApiario.Count() colmenas</div>
            </div>
        </div>
    </div>

    <div class="map-ph" style="height: 100%; min-height: 200px;">
        <div class="map-ph-pins">📍</div>
        <div class="map-ph-lbl">Ubicación GPS: @(Model.Latitud?.ToString() ?? "N/A"), @(Model.Longitud?.ToString() ?? "N/A")</div>
        <div class="map-ph-sub">Fuente de agua cercana: @(Model.FuenteAgua ? "Sí ✓" : "No ✗")</div>
    </div>
</div>

<div class="card">
    <div class="card-hd">
        <div class="card-title">Colmenas en este Apiario</div>
        <span class="pill p-ghost">@colmenasEnApiario.Count() registradas</span>
    </div>
    @if (!colmenasEnApiario.Any())
    {
        <div style="padding: 30px; text-align: center; color: var(--txt-4);">
            <div style="font-size: 24px; margin-bottom: 8px;">🏠</div>
            <p>No hay colmenas registradas en este apiario actualmente.</p>
        </div>
    }
    else
    {
        <div class="tbl-wrap" style="border: none; border-radius: 0;">
            <table>
                <thead>
                    <tr>
                        <th>Código</th>
                        <th>Tipo</th>
                        <th>Estado Reina</th>
                        <th>Última visita</th>
                        <th>Semáforo</th>
                        <th>Alzas</th>
                        <th>Observaciones</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var colmena in colmenasEnApiario)
                    {
                        <tr>
                            <td class="td-1">@colmena.Codigo</td>
                            <td>@colmena.Tipo</td>
                            <td>
                                @if (colmena.EstadoReina == "vista")      { <span style="color:var(--green)">✓ Vista</span> }
                                else if (colmena.EstadoReina == "no_vista") { <span style="color:var(--amber)">? No vista</span> }
                                else                                       { <span style="color:var(--red)">✗ Ausente</span> }
                            </td>
                            <td>@(colmena.UltimaVisita.HasValue ? $"Hace {(DateTime.Now - colmena.UltimaVisita.Value).Days} días" : "Sin visitas")</td>
                            <td><span class="pill p-@colmena.EstadoSemaforo">@colmena.EstadoSemaforo</span></td>
                            <td class="td-1">@colmena.CantidadAlzas</td>
                            <td style="max-width: 200px; overflow: hidden; text-overflow: ellipsis; white-space: nowrap;">@colmena.Observaciones</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</div>
